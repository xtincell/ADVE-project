// ============================================================================
// NEXTAUTH MODELS
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// EXISTING MODELS (stubs with key fields for relations)
// ============================================================================

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  hashedPassword   String?
  image            String?
  role             String    @default("USER")
  operatorId       String?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  operator          Operator?            @relation(fields: [operatorId], references: [id])
  accounts          Account[]
  sessions          Session[]
  qualityReviews    QualityReview[]
  talentProfile     TalentProfile?
  auditLogs         AuditLog[]
  campaignTeam      CampaignTeamMember[]
  campaignApprovals CampaignApproval[]
  deals             Deal[]
  socialConnections SocialConnection[]

  // Phase 18-A1-β/γ — assignations sur tickets de modif + actions opérationnelles
  changeRequestAssignments  CampaignChangeRequest[] @relation("ChangeRequestAssignee")
  operatorActionAssignments OperatorAction[]        @relation("OperatorActionAssignee")

  // Vague 7 — candidatures aux missions ouvertes (créas/agences)
  missionApplications MissionApplication[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isDummy   Boolean    @default(false)
  Strategy  Strategy[]
}

model Operator {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  status         OperatorStatus
  licenseType    LicenseType
  licensedAt     DateTime
  licenseExpiry  DateTime
  branding       Json?
  maxBrands      Int            @default(50)
  commissionRate Float          @default(0.10)

  // Chantier 5 — Type et spécialisation
  agencyType      AgencyType @default(COMMUNICATION)
  specializations String[]   @default([])

  // Chantier 5 — Hiérarchie (UPgraders = null = racine)
  parentId String?
  parent   Operator?  @relation("OperatorHierarchy", fields: [parentId], references: [id])
  children Operator[] @relation("OperatorHierarchy")

  users             User[]
  strategies        Strategy[]
  clients           Client[]
  clientAllocations ClientAllocation[]
  connectors        ExternalConnector[] // v4 — inbound SaaS connectors (Monday, Zoho, etc.)

  // Phase 18 (ADR-0059) — Brand Tree multi-archétype : un Operator gère N BrandNode.
  brandNodes            BrandNode[]
  delegatedDeliverables CampaignDeliverable[]  @relation("DeliverableDelegate")
  // Phase 18-A1-γ — Actions opérationnelles transverses portées par cet operator.
  operatorActions       OperatorAction[]       @relation("OperatorActions")
  // Phase 18-A1-δ — Sources ingérées + batches Morning Brief Batch
  ingestedSources       IngestedSource[]       @relation("OperatorIngestedSources")
  morningBatches        MorningBriefBatch[]    @relation("OperatorMorningBatches")
  // Phase 18 résidus — formulaire de session future (cf. /console/governance/phase-18-residuals)
  phase18Residuals      Phase18ResidualEntry[] @relation("OperatorPhase18Residuals")

  dataRegion String @default("eu-west") // v4 — data residency region

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDummy   Boolean  @default(false)
}

// Chantier 5 — Allocation client multi-agences
model ClientAllocation {
  id         String         @id @default(cuid())
  clientId   String
  operatorId String
  role       AllocationRole @default(LEAD)
  scope      String[]       @default([]) // ["BRANDING", "SOCIAL_MEDIA", "PR", ...]
  startDate  DateTime       @default(now())
  endDate    DateTime?

  // Phase 18 (ADR-0059) — Permissions par sous-arbre BrandNode.
  // null = scope client entier (rétrocompatible). non-null = scope sur ce BrandNode + descendance selon scopeMode.
  scopeNodeId String?
  scopeNode   BrandNode? @relation(fields: [scopeNodeId], references: [id])
  /// NODE_ONLY = ce nœud uniquement | NODE_AND_DESCENDANTS = nœud + toute la descendance
  scopeMode   String     @default("NODE_AND_DESCENDANTS")

  client   Client   @relation(fields: [clientId], references: [id])
  operator Operator @relation(fields: [operatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, operatorId])
  @@index([scopeNodeId])
}

model Client {
  id           String  @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  sector       String?
  country      String?
  notes        String?
  billingInfo  Json?
  operatorId   String
  status       String  @default("ACTIVE")

  operator    Operator           @relation(fields: [operatorId], references: [id])
  strategies  Strategy[]
  allocations ClientAllocation[] // Chantier 5 — multi-agence
  brandNodes  BrandNode[] // Phase 18 (ADR-0059) — Brand Tree

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
  @@index([contactEmail])
}

model Strategy {
  id                String         @id @default(cuid())
  name              String
  description       String?
  userId            String
  operatorId        String?
  clientId          String?
  advertis_vector   Json?
  businessContext   Json?
  /// Thot-computed financial capacity (FinancialCapacity shape — see capacity.ts)
  financialCapacity Json?
  status            String         @default("ACTIVE")
  brandNature       BrandNature?
  primaryChannel    DriverChannel?
  /// ISO-2 country code — indexed lookup; mirrors businessContext.country.
  /// Single source of truth for currency / market benchmarks routing.
  countryCode       String?        @db.VarChar(2)
  /// ISO-4217 currency code derived from countryCode at write time.
  currencyCode      String?        @db.VarChar(3)

  user               User                      @relation(fields: [userId], references: [id])
  operator           Operator?                 @relation(fields: [operatorId], references: [id])
  client             Client?                   @relation(fields: [clientId], references: [id])
  drivers            Driver[]
  devotionSnapshots  DevotionSnapshot[]
  processes          Process[]
  campaigns          Campaign[]
  missions           Mission[]
  signals            Signal[]
  gloryOutputs       GloryOutput[]
  brandAssets        BrandAsset[]
  sequenceExecutions SequenceExecution[]
  pillars            Pillar[]
  cultIndexSnapshots CultIndexSnapshot[]
  superfanProfiles   SuperfanProfile[]
  communitySnapshots CommunitySnapshot[]
  socialConnections  SocialConnection[]
  socialPosts        SocialPost[]
  mediaConnections   MediaPlatformConnection[]
  pressReleases      PressRelease[]
  pressClippings     PressClipping[]
  marketStudies      MarketStudy[]
  ambassadorProgram  AmbassadorProgram?
  brandVariables     BrandVariable[]
  frameworkResults   FrameworkResult[]
  deals              Deal[]
  contracts          Contract[]
  insightReports     InsightReport[]
  attributionEvents  AttributionEvent[]
  cohortSnapshots    CohortSnapshot[]
  scoreSnapshots     ScoreSnapshot[]
  dataSources        BrandDataSource[]
  orchestrationPlans OrchestrationPlan[]
  recommendations    Recommendation[]
  recoBatches        RecommendationBatch[]
  notoriaPipeline    Json? // { currentStage, stages[], startedAt }
  jehutyCurations    JehutyCuration[]
  // ADR-0029 — back-relation for QuickIntake.convertedTo (FK SetNull on Strategy purge).
  quickIntakes       QuickIntake[]             @relation("QuickIntakeConvertedTo")

  // Phase 18 (ADR-0059) — Brand Tree : 1 Strategy d'exploitation peut être rattachée à
  // un BrandNode opérationnel (REGIONAL_BRAND ou SKU déployé). Cardinality 1:N car le
  // backfill rattache initialement chaque Strategy à 1 BrandNode `STANDALONE_BRAND`.
  brandNodes BrandNode[]

  // Phase 21 (ADR-0068) — 35 OracleSection × strategyId. Lifecycle PENDING → GENERATING
  // → COMPLETE → FAILED → STALE. Voir oracle-section/ service + schema bottom-of-file.
  oracleSections OracleSection[]

  // v4 — LLM budget governance
  llmBudget       Float? // Monthly USD cap for LLM calls on this strategy
  llmBudgetAlerts Json? // { "75": false, "90": false, "100": false }

  // v4 — multi-tenant RLS
  tenantId String?

  // Phase 9 (ADR-0009 Ptah) — Manipulation Matrix mix : { peddler, dealer, facilitator, entertainer } sum=1
  manipulationMix           Json? // null = uniforme implicite (0.25 chacun) jusqu'à back-fill
  // Phase 9 — cult index agrégé (alimenté par Seshat asset-impact-tracker)
  cultIndex                 Float?
  // Phase 9 — log des overrides MIX_VIOLATION (audit)
  mixViolationOverrideCount Int    @default(0)

  // Phase 19 — Campaign tracker (ADR-0052 §2.5) — gates strict-mode opt-in par tenant.
  // Si une string match un nom de gate (ex: "MANIPULATION_COHERENCE_PER_ACTION"), le gate est activé.
  // Sans cette colonne ou liste vide, les gates L2 sont en mode SOFT (warnings) — L1 jamais bloqué.
  strictModeGates Json? // string[]

  // Phase 19 (ADR-0052-B) — bascule Cluster B Jaccard heuristic → Glory tool LLM eval.
  // Default null = "lexical" (MVP heuristic). Opt-in "llm" = bascule vers
  // `big-idea-coherence-checker` + `myth-arc-cohesion-evaluator` Glory tools.
  evaluatorMode String?

  // Phase 10 (ADR-0012) — Brand vault (intellectual + material assets unifiés)
  // Note: la relation BrandAsset[] existait déjà via brandAssets ci-dessus.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDummy   Boolean  @default(false)

  // Phase 16+ (Strategy archive system) — soft archive marker.
  // null = active. set = archived (hidden from default queries, restorable
  // via OPERATOR_RESTORE_STRATEGY, hard-deletable via OPERATOR_PURGE_STRATEGY).
  archivedAt DateTime?

  @@index([clientId])
  @@index([tenantId])
  @@index([archivedAt])
}

model Campaign {
  id                String        @id @default(cuid())
  name              String
  strategyId        String
  advertis_vector   Json?
  devotionObjective Json?
  status            String        @default("DRAFT")
  state             CampaignState @default(BRIEF_DRAFT)
  budget            Float?
  budgetCurrency    String        @default("XAF")
  startDate         DateTime?
  endDate           DateTime?
  objectives        Json?
  aarrTargets       Json?
  parentCampaignId  String?
  code              String? // CAMP-YYYY-### auto-generated code

  // Phase 18 (ADR-0059) — Workflow dual révélé par BACK2SCH project tracker (statut créa | statut client).
  // Phase 18-A1 (audit MATANGA V4) — re-typage en enums first-class alignés sur les 5 statuts
  // officiels V4 (REGISTRE PROJETS sheet) + workflow client.
  // Le `state: CampaignState` reste la machine canonique legacy (BRIEF_DRAFT...ARCHIVED) pour
  // backward compat. Les deux statuts ci-dessous capturent la granularité opérationnelle agence.
  creativeState     CreativeProductionStatus @default(BRIEF_RECU)
  clientState       ClientReviewStatus       @default(PENDING)
  /// GREEN | AMBER | RED — calculé via helper computeRAG(campaign) à partir de deadline_proximity + creativeState + clientState + delivered_ratio + isCritical + blockers
  healthSignal      String                   @default("GREEN")
  /// Si non-null : override manuel par opérateur (computeRAG ignoré). Audit conservé via Mestor Intent OPERATOR_OVERRIDE_RAG.
  manualRagOverride String?
  /// Dernier commentaire libre (pour vue Project Tracker dashboard agence).
  commentsLatest    String?
  // Phase 18-A1 — Flag orthogonal "🔴 CRITIQUE" V4. computeRAG → AMBER min si TRUE,
  // RED si TRUE + deadline_proximity < 3j ou status BLOQUE. Indépendant de creativeState
  // (un projet EN_PRODUCTION peut devenir CRITIQUE sans changer de statut).
  isCritical        Boolean                  @default(false)
  // Phase 18-A1 — Priorité opérationnelle (V4 sheet ACTIONS column PRIORITÉ).
  priority          OperationalPriority      @default(MOYENNE)

  strategy       Strategy                @relation(fields: [strategyId], references: [id])
  missions       Mission[]
  actions        CampaignAction[]
  executions     CampaignExecution[]
  amplifications CampaignAmplification[]
  teamMembers    CampaignTeamMember[]
  milestones     CampaignMilestone[]
  approvals      CampaignApproval[]
  assets         CampaignAsset[]
  briefs         CampaignBrief[]
  reports        CampaignReport[]
  dependencies   CampaignDependency[]    @relation("source")
  dependedBy     CampaignDependency[]    @relation("target")
  fieldOps       CampaignFieldOp[]
  fieldReports   CampaignFieldReport[]
  aarrMetrics    CampaignAARRMetric[]
  links          CampaignLink[]
  budgetLines    BudgetLine[]

  // Phase 10 (ADR-0012) — BrandAssets actifs sélectionnés parmi candidats.
  // Une Campaign garde 1 BrandAsset ACTIVE par kind clé (BigIdea/Brief/Claim/Manifesto/KV).
  brandAssets       BrandAsset[]
  activeBigIdeaId   String? // → BrandAsset.id (kind=BIG_IDEA, state=ACTIVE)
  activeBriefId     String? // → BrandAsset.id (kind=CREATIVE_BRIEF)
  activeClaimId     String? // → BrandAsset.id (kind=CLAIM)
  activeManifestoId String? // → BrandAsset.id (kind=MANIFESTO)
  activeKvBriefId   String? // → BrandAsset.id (kind=KV_ART_DIRECTION_BRIEF)

  // Phase 18 (ADR-0059) — Matrice 6D de livrables (CampaignDeliverable révélé par RAMADAN.xlsx).
  deliverables    CampaignDeliverable[]
  // Phase 18-A1-γ — Actions opérationnelles transverses rattachées à cette campagne.
  operatorActions OperatorAction[]      @relation("CampaignOperatorActions")

  // Phase 19 — Campaign tracker L2 Instrumental (ADR-0052 Cluster A — Trajectoire & altitude).
  // L2 lecture composée sur L1, snapshots immutables une fois Campaign.state = LIVE.
  tierBrandSnapshot  Json? // BrandClassification figée READY_TO_LAUNCH → LIVE : {tier, compositeScore, byPillar, snapshotAt}
  tierBrandFinal     Json? // Idem post-POST_CAMPAIGN (J+7 stabilisation Seshat)
  altitudeRegression Boolean? // Loi 1 audit — true si une dimension byPillar régressée silencieusement (LAW_1_SILENT_REGRESSION)
  killTriggeredAt    DateTime? // Thot Loi 3 — auto-pause flame-out (THOT_PAUSE_CAMPAIGN_FLAME_OUT)

  // Phase 19 — Campaign tracker L2 Instrumental (ADR-0052 Cluster B — Cohérence narrative).
  bigIdeaSnapshotBrandAssetId   String? // → BrandAsset.id du BigIdea ACTIVE au lancement (content figé via Json snapshot)
  manifestoSnapshotBrandAssetId String? // → BrandAsset.id du Manifesto ACTIVE au lancement
  bigIdeaSnapshotContent        Json? // Snapshot immutable du BrandAsset.content au passage LIVE (anti-drift édition aval)
  manifestoSnapshotContent      Json? // Idem pour le Manifesto
  manipulationMixSnapshot       Json? // Copie figée Strategy.manipulationMix au lancement
  cultIndexSnapshotPre          Json? // CultIndex pré-LIVE (null-honest cf. ADR-0046)
  cultIndexSnapshotPost         Json? // CultIndex post-POST_CAMPAIGN

  // Phase 19 Vague 2 — Campaign tracker (ADR-0052 Cluster C — Superfan economy).
  detractorsCount          Int? // Comptage anti-superfans (haters, communauté hostile)
  detractorsSentimentScore Float? // Score 0..1 sentiment des détracteurs (0 = neutre, 1 = très négatif)
  shadowReachEarned        Int? // Reach earned attribué aux superfans existants (UGC géolocalisé, mentions organiques)

  // Phase 19 Vague 2 — Campaign tracker (ADR-0052 Cluster D — Signaux faibles & culture).
  overtonHypothesis Json? // Figée au lancement : { axe, sentimentDepart, sectorTokens[] }
  overtonObserved   Json? // Mesurée à POST_CAMPAIGN : { sentimentFinal, vocabularyShift, references[] }

  // Phase 19 Vague 3 — Campaign tracker (ADR-0052 Cluster F — Économie agence).
  forksDeclined Json? // [{forkId, modeDeclined, reasonDeclined, decidedAt}] — alternatives non-prises (Manipulation Matrix)
  frictionScore Float? // 0..1 — agrégé approval rounds + retards client + désaccords créatifs

  // Phase 19 Vague 3 — Campaign tracker (ADR-0052 Cluster G — Souveraineté opérationnelle).
  credentialsChainSnapshot Json? // Snapshot ExternalConnector.id[] utilisés au lancement LIVE (audit chain of custody)

  // Phase 23 (ADR-0081 + ADR-0080) — Pivot mechanics.
  // Operator-supplied attribution coefficients for the manual-first peer mode
  // (FR25). Shape `Record<string, number>` mirroring the regression's
  // coefficients output. When non-null, RUN_ATTRIBUTION_CALIBRATION mode
  // MANUAL_COEFFICIENTS uses these directly instead of fitting via gradient
  // descent. Source-discriminated downstream via IntentEmission.payload.source.
  attributionCoefficients      Json?
  // Active calibration snapshot pointer. Set on calibration acceptance ;
  // referenced by PROMOTE_PIVOT_SUBCLUSTER.calibrationSnapshotRef when promoting
  // superfan.attribution to PRODUCTION. The value is an IntentEmission.id
  // (RUN_ATTRIBUTION_CALIBRATION kind). Hash-chained traceability per ADR-0080.
  activeCalibrationSnapshotRef String?

  tenantId String? // v4 — multi-tenant RLS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId])
  @@index([state])
  @@index([tenantId])
  @@index([killTriggeredAt])
  @@index([healthSignal])
  @@index([creativeState])
  @@index([clientState])
  @@index([isCritical])
  @@index([priority])
}

