// ═══════════════════════════════════════════════════════════════════
// V5 — NETERU INTENT GOVERNANCE
// All work that touches pillars / recommendations / deliverables flows
// through Mestor.emitIntent → Artemis.commandant.execute. This audit
// table captures every emission so we can replay, debug, and analyse.
// ═══════════════════════════════════════════════════════════════════

model IntentEmission {
  id         String @id @default(cuid())
  intentKind String // FILL_ADVE | RANK_PEERS | LIFT_INTAKE_TO_STRATEGY | LEGACY_MUTATION | ...
  strategyId String
  payload    Json // serialized Intent
  result     Json? // serialized IntentResult (filled after dispatch)
  caller     String @default("unknown") // emitter module (quick-intake, boot-sequence, strangler:<router>:<proc>...)

  // Phase 3 additions
  version     Int      @default(1)
  spawnedFrom String? // intentId that spawned this one (Mestor → Mestor)
  governor    String   @default("MESTOR") // MESTOR | ARTEMIS | SESHAT | THOT | INFRASTRUCTURE
  costUsd     Decimal? @db.Decimal(12, 4)
  startedAt   DateTime @default(now())
  status      String   @default("PENDING") // PENDING | OK | VETOED | DOWNGRADED | FAILED | QUEUED

  // ADR-0038 — Découplage status / observationStatus (Phase 16-bis APOGEE anti-drift).
  // Le `status` couvre l'exécution synchrone du handler (handler returned cleanly).
  // L'`observationStatus` couvre la boucle Seshat asynchrone (the effect was *measured*
  // and indexed — Tarsis weak signals, asset impact tracker, knowledge graph rewrite).
  // Une combustion peut donc être OK côté handler mais STALE côté observation
  // (cron retry queue prend le relais — cf. seshat-bridge / asset-impact cron).
  // Default PENDING_OBSERVATION ; flip à OBSERVED par Seshat ou STALE_OBSERVATION par cron staleness.
  observationStatus String    @default("PENDING_OBSERVATION") // PENDING_OBSERVATION | OBSERVED | STALE_OBSERVATION | OBSERVATION_FAILED | NOT_APPLICABLE
  observedAt        DateTime?
  observationError  String?

  // Hash-chain integrity (Phase 3)
  prevHash String?
  selfHash String?

  emittedAt   DateTime  @default(now())
  completedAt DateTime?

  events IntentEmissionEvent[]

  @@index([strategyId, emittedAt])
  @@index([strategyId, status])
  @@index([intentKind, status])
  @@index([intentKind, emittedAt])
  @@index([caller])
  @@index([spawnedFrom])
  @@index([observationStatus, emittedAt])
}

// Phase 3 — IntentEmissionEvent: 1:N progress events streamed via NSP.
model IntentEmissionEvent {
  id        String         @id @default(cuid())
  intentId  String
  intent    IntentEmission @relation(fields: [intentId], references: [id], onDelete: Cascade)
  phase     String // PROPOSED | DELIBERATED | DISPATCHED | EXECUTING | OBSERVED | COMPLETED | FAILED | VETOED | DOWNGRADED
  stepName  String?
  stepIndex Int?
  stepTotal Int?
  partial   Json?
  costUsd   Decimal?       @db.Decimal(12, 4)
  emittedAt DateTime       @default(now())

  @@index([intentId, emittedAt])
  @@index([phase, emittedAt])
}

// Phase 3 — IntentQueue: pending async intents picked up by the cron.
model IntentQueue {
  id         String   @id @default(cuid())
  intentId   String   @unique
  kind       String
  strategyId String
  payload    Json
  enqueuedAt DateTime @default(now())
  attempts   Int      @default(0)
  status     String   @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  lastError  String?
  notBefore  DateTime @default(now())

  @@index([status, notBefore])
  @@index([kind, enqueuedAt])
}

// Country / Currency registry — typed source of truth for market routing.
// Replaces the hardcoded constants in
// `src/server/services/financial-brain/benchmarks/purchasing-power.ts`
// and `src/server/services/financial-engine/index.ts`. Wakanda is a
// first-class row (parity with FCFA, see seed).
model Currency {
  /// ISO-4217 code (XAF, XOF, EUR, USD, …) — primary key.
  code          String    @id @db.VarChar(3)
  name          String
  symbol        String    @default("")
  /// Decimal places used in display (XAF=0, EUR=2, …).
  decimalPlaces Int       @default(2)
  /// Reference rate vs USD at last refresh — informational, NOT used as a
  /// live FX feed. Real conversion calls a ratesProvider service.
  usdRate       Float?
  countries     Country[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Country {
  /// ISO-3166-1 alpha-2 (CM, CI, SN, FR, US, WK for Wakanda…).
  code                 String   @id @db.VarChar(2)
  name                 String   @unique
  /// FR / EN / PT / AR — drives prompt + UI localisation defaults.
  primaryLanguage      String   @default("fr")
  currencyCode         String   @db.VarChar(3)
  currency             Currency @relation(fields: [currencyCode], references: [code])
  /// Purchasing-power index relative to a baseline of 100 (Cameroun).
  /// Used by financial-brain to scale benchmarks across markets.
  purchasingPowerIndex Float    @default(100)
  /// Continent / region tag for grouping in UI and Seshat queries.
  region               String   @default("AFRICA")
  /// True for fictional / test environments (Wakanda).
  isFictional          Boolean  @default(false)
  /// Additional market metadata — populated by Seshat ingest, free shape.
  marketMeta           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([region])
  @@index([currencyCode])
}

// Phase 7 — OracleSnapshot: time-travel for the dynamic Oracle.
model OracleSnapshot {
  id             String   @id @default(cuid())
  strategyId     String
  takenAt        DateTime @default(now())
  schemaVersion  Int      @default(1)
  parentIntentId String?
  lang           String   @default("fr")
  snapshotJson   Json

  @@index([strategyId, takenAt])
}

// Phase 7 — IntegrationConnection: OAuth tokens (encrypted at rest).
model IntegrationConnection {
  id              String    @id @default(cuid())
  operatorId      String
  provider        String // google | meta | linkedin | ...
  externalUserId  String?
  encryptedTokens String // AES-GCM ciphertext (base64), key in env
  scopes          String[]
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([operatorId, provider, externalUserId])
  @@index([operatorId, provider])
}

/// Governance — `purpose → model` resolution policy used by the LLM Gateway.
///
/// Each row maps an operational purpose (e.g. "final-report", "agent",
/// "intake-followup") to the concrete Anthropic model name AND the optional
/// Ollama substitute. The policy is hash-chained through IntentEmission
/// (kind=UPDATE_MODEL_POLICY) so every change to "what model serves which
/// scenario" is auditable.
///
/// `version` increments on every UPDATE_MODEL_POLICY emission. Rolling back
/// to a prior version is just another UPDATE_MODEL_POLICY.
model ModelPolicy {
  id                      String   @id @default(cuid())
  /// Stable purpose key — see GatewayPurpose in llm-gateway.
  purpose                 String   @unique
  /// Anthropic model name (e.g. "claude-opus-4-20250514").
  anthropicModel          String
  /// Ollama model name (e.g. "llama3.1:70b") OR null when no substitute is acceptable.
  ollamaModel             String?
  /// True iff the gateway may substitute Ollama for Anthropic when both are available.
  /// Final-report-class purposes are typically false (quality matters more than cost).
  allowOllamaSubstitution Boolean  @default(false)
  /// Pipeline variant used by callers that branch on it. "V1" = direct
  /// (legacy, what every caller has historically done), "V2" = RAG-augmented
  /// two-pass (Sonnet brief synthesis + Opus final write). Allows opt-in
  /// per purpose without code change.
  pipelineVersion         String   @default("V1")
  /// Free-form explanation of why this policy exists — read by admins, audited.
  notes                   String?
  /// Monotonically increasing version. Bumped by UPDATE_MODEL_POLICY.
  version                 Int      @default(1)
  /// User id (operator) who issued the last UPDATE_MODEL_POLICY for this purpose.
  updatedBy               String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([purpose])
}

// Phase 7 — MfaSecret: TOTP secrets for ADMIN MFA.
model MfaSecret {
  id                  String    @id @default(cuid())
  userId              String    @unique
  secretCipher        String // AES-GCM ciphertext of TOTP secret
  enrolledAt          DateTime  @default(now())
  lastUsedAt          DateTime?
  recoveryCodesCipher String? // AES-GCM ciphertext of recovery codes JSON
}

// ═══════════════════════════════════════════════════════════════════
// V5 — SESHAT MARKET DATA STORE (TIER 1 — relational source of truth)
// Structured first, vectorized later. All Neteru consult these tables
// for real benchmarks (CPM, salaries, prod costs, market sizing, etc.).
// ═══════════════════════════════════════════════════════════════════

model MarketBenchmark {
  id            String  @id @default(cuid())
  country       String // ISO-2, e.g. "CM", "CI", "FR"
  sector        String // FMCG, BANQUE, TECH, ...
  businessModel String? // B2C, B2B, B2B2C, D2C, MARKETPLACE
  brandNature   String? // PRODUCT, SERVICE, FESTIVAL, ...
  premiumScope  String? // NONE, RANGE, BRAND, FULL
  metric        String // CPM_META, CPC_GOOGLE, CPA_LEAD, PROD_SPOT_30S, SALARY_DIRECTOR, RETAINER_AGENCY, INFLUENCER_FOLLOWER, ...
  unit          String // FCFA, EUR, USD, %, count
  // Distribution rather than a single value
  p10           Float
  p50           Float
  p90           Float
  sampleSize    Int     @default(0)
  sourceRef     Json? // [{ name, url, year, notes }]
  confidence    Float   @default(0.5) // 0..1
  notes         String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastReviewedAt DateTime?

  @@index([country, sector, metric])
  @@index([metric])
}

/// Coûts marché HISTORISÉS par (pays, secteur, métrique, période) — ADR-0094.
/// Complète MarketBenchmark (snapshot statique courant) avec l'axe TEMPS : une
/// série de coûts réels (CPM/CPC/prod/salaires/cost-of-living) datés, requêtable
/// « tel marché à telle période ». Déterministe (DB-only, zéro LLM). Distinct des
/// ZoneIndex ADR-0087 (multiplicateurs d'indice) — ici ce sont des COÛTS bruts.
model MarketCostSnapshot {
  id          String   @id @default(cuid())
  countryCode String // ISO-2, e.g. "CM", "CI", "SN"
  sector      String   @default("ALL") // "ALL" = cross-secteur
  metric      String // CPM_META, CPC_GOOGLE, PROD_SPOT_30S, SALARY_DIRECTOR, COST_OF_LIVING_INDEX, ...
  /// Clé de période canonique : "2026" | "2026-Q2" | "2026-06" (granularité libre).
  period      String
  periodStart DateTime
  periodEnd   DateTime
  unit        String   @default("FCFA") // FCFA, EUR, USD, %, index
  currency    String   @default("XAF")
  // Distribution (p50 = valeur de référence).
  p10         Float?
  p50         Float
  p90         Float?
  sampleSize  Int      @default(0)
  source      String   @default("SEED") // SEED | OPERATOR | CONNECTOR | COMPUTED
  sourceRef   Json? // [{ name, url, year, notes }]
  confidence  Float    @default(0.5)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryCode, sector, metric, period])
  @@index([countryCode, sector, metric, periodStart])
  @@index([metric, periodStart])
}

model MarketSizing {
  id         String  @id @default(cuid())
  country    String
  sector     String
  segment    String? // optional sub-segment
  year       Int
  TAM        Float? // Total Addressable Market
  SAM        Float? // Serviceable Available Market
  SOM        Float? // Serviceable Obtainable Market
  currency   String  @default("FCFA")
  growthRate Float? // YoY % (0.05 = 5%)
  sourceRef  Json?
  confidence Float   @default(0.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([country, sector, segment, year])
  @@index([country, sector])
}

model CostStructure {
  id             String  @id @default(cuid())
  sector         String
  businessModel  String?
  line           String // PRODUCTION | MEDIA | TALENT | TECH | OPS | OVERHEAD
  // Distribution of this line item as % of revenue
  pctRevenue_p10 Float
  pctRevenue_p50 Float
  pctRevenue_p90 Float
  sourceRef      Json?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sector, line])
}

model CompetitiveLandscape {
  id          String  @id @default(cuid())
  country     String
  sector      String
  segment     String?
  year        Int
  leaderShare Float? // 0..1
  top3HHI     Float? // Herfindahl-Hirschman Index (0..1)
  notes       String?
  sourceRef   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([country, sector, segment, year])
  @@index([country, sector])
}

model MarketDocument {
  id          String    @id @default(cuid())
  title       String
  country     String?
  sector      String?
  year        Int?
  topics      String[]  @default([]) // e.g. ["FMCG","BIA","Cameroun"]
  frontmatter Json? // structured metadata
  body        String    @db.Text // markdown content
  sourceRef   Json?
  /// When indexed into Tier 3 vector store
  indexedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country, sector])
}

// ═══════════════════════════════════════════════════════════════════
// V5 — SESHAT BRAND/MARKET CONTEXT NODES (TIER 3 — vector-ready)
// Each node aggregates one piece of brand or market context with its
// structured payload + (future) embedding. Embedding stored as Float[]
// for now — when pgvector is enabled, swap to vector(1536) via raw SQL
// migration without breaking the model.
// ═══════════════════════════════════════════════════════════════════

model BrandContextNode {
  id                String  @id @default(cuid())
  strategyId        String
  /// PILLAR_FIELD | NARRATIVE | BRANDLEVEL | RECO | ASSET | SEQUENCE_OUTPUT
  kind              String
  /// Optional pillar key when kind is PILLAR_FIELD or RECO (a/d/v/e/r/t/i/s)
  pillarKey         String?
  /// Optional field name for PILLAR_FIELD nodes
  field             String?
  /// Source-specific identifier (e.g. recoId, assetId)
  sourceId          String?
  /// Structured payload — the human-readable content
  payload           Json
  /// Embedding vector — variable length depending on model
  embedding         Float[] @default([])
  /// Provider that produced the embedding (ollama | openai | none)
  embeddingProvider String?
  /// Model name (e.g. nomic-embed-text, text-embedding-3-small) — used to
  /// avoid mixing different-dim vectors in similarity searches
  embeddingModel    String?
  /// Dim of the embedding (denormalized for fast filtering)
  embeddingDim      Int?
  /// Filtering metadata: {country, sector, businessModel, financialCapacityTier, ...}
  metadata          Json?
  /// Hash of payload to detect changes and trigger re-embedding
  contentHash       String?

  // Phase 18-N3 (ADR-0059) — Tree-aware RAG context. Lien direct vers le BrandNode
  // qui possède ce contexte (vs strategyId qui reste pour backward compat). Le
  // retriever arborescent (N4) remonte l'arbre via nodeId → parent → racine pour
  // collecter le contexte cumulé.
  nodeId String?
  node   BrandNode? @relation("BrandNodeContextNodes", fields: [nodeId], references: [id])

  /// Quels niveaux d'arbre peuvent retrieve ce contextNode lors d'un search.
  /// Default `["SELF"]` = visible uniquement sur le node directement attaché.
  /// `["SELF", "DESCENDANTS"]` = visible aussi sur les enfants (cas tone-of-voice
  /// master qui descend aux regional brands). `["SELF", "ANCESTORS"]` = visible
  /// aussi sur les ancêtres (cas signal terrain régional qui doit remonter au master).
  /// `["SELF", "ANCESTORS", "DESCENDANTS"]` = visible partout dans l'arbre (rare).
  retrievalScope String[] @default(["SELF"])

  embeddedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([strategyId, kind])
  @@index([strategyId, pillarKey])
  @@index([sourceId])
  @@index([embeddedAt])
  @@index([nodeId])
  @@index([nodeId, kind])
  @@index([embeddingModel])
}

model MarketContextNode {
  id          String  @id @default(cuid())
  /// BENCHMARK | DOCUMENT | SIZING | LANDSCAPE
  kind        String
  /// Reference to the source row id (MarketBenchmark.id, MarketDocument.id, ...)
  refId       String
  /// Structured payload (denormalized snapshot)
  payload     Json
  /// Embedding (1536 dims) — null until embedded
  embedding   Float[] @default([])
  /// Filtering metadata: {country, sector, metric, ...}
  metadata    Json?
  contentHash String?

  embeddedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([kind, refId])
  @@index([kind])
  @@index([embeddedAt])
}

// ═══════════════════════════════════════════════════════════════════
// V5 — STRUCTURED BRAND ACTIONS (Pillar I taxonomy)
// Pillar I content used to be a free-form JSON. Now: each action is a
// typed row with touchpoint, AARRR intent, persona, SKU, budget envelope,
// locality, timing — so they can be filtered, sorted, selected, and used
// to feed the dynamic S synthesis.
// ═══════════════════════════════════════════════════════════════════

model BrandAction {
  id               String    @id @default(cuid())
  strategyId       String
  /// Short title for the action
  title            String
  /// 1-2 sentence description
  description      String?   @db.Text
  /// Touchpoint family: DIGITAL | ATL | BTL | TTL | OWNED | EARNED
  touchpoint       String?
  /// AARRR intent: ACQUISITION | ACTIVATION | RETENTION | REFERRAL | REVENUE
  aarrrIntent      String?
  /// Persona slug or label
  persona          String?
  /// SKU / product line
  sku              String?
  /// Budget envelope (FCFA or strategy currency)
  budgetMin        Float?
  budgetMax        Float?
  budgetCurrency   String?   @default("XAF")
  /// Opportunity tag (LAUNCH | CRISIS | EVENT | SEASONAL | ALWAYS_ON | ...)
  opportunity      String?
  /// Geographic scope
  locality         String?
  /// Time window
  timingStart      DateTime?
  timingEnd        DateTime?
  /// Manager priority: P0 | P1 | P2 | P3
  priority         String?   @default("P2")
  /// Whether the strategist has selected this action for inclusion in S synthesis
  selected         Boolean   @default(false)
  /// Source: NOTORIA_GENERATED | OPERATOR_MANUAL | SEED
  source           String    @default("NOTORIA_GENERATED")
  /// Optional reference to the Notoria recommendation that produced this action
  recoId           String?
  /// Optional reference to the Intent that emitted the generation
  intentEmissionId String?
  /// Free-form parameters envelope (any extra KPIs, references)
  metadata         Json?
  /// Status: DRAFT | PROPOSED | ACCEPTED | SCHEDULED | EXECUTED | CANCELLED
  status           String    @default("PROPOSED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId, status])
  @@index([strategyId, selected])
  @@index([touchpoint, aarrrIntent])
  @@index([recoId])
}

// ═══════════════════════════════════════════════════════════════════
// V5 — STRATEGY FINANCIAL CAPACITY (Thot anchor)
// Stored on Strategy as JSON via the financialCapacity column added below.
// QuickIntake gets a financialResponses field to store direct biz answers.
// ═══════════════════════════════════════════════════════════════════
//
// NOTE: the actual columns (Strategy.financialCapacity, QuickIntake.financialResponses)
// are added inline on the existing models in a follow-up edit, since modifying those
// in-place risks losing relational fields.

// ═══════════════════════════════════════════════════════════════════
// APOGEE Phase 3 — Cost gate (Pillar 6) + Sector first-class + Strategy CRDT doc
// ═══════════════════════════════════════════════════════════════════

/// Cost gate decision per Intent — Thot's audit trail (separate from
/// IntentEmission so Thot's reasoning is queryable independently).
model CostDecision {
  id                 String   @id @default(cuid())
  intentEmissionId   String   @unique
  intentKind         String
  operatorId         String
  strategyId         String?
  /// ALLOW | DOWNGRADE | VETO
  decision           String
  estimatedUsd       Decimal  @db.Decimal(12, 4)
  remainingBudgetUsd Decimal  @db.Decimal(12, 4)
  downgradeFromTier  String?
  downgradeToTier    String?
  reason             String
  decidedAt          DateTime @default(now())

  @@index([operatorId, decidedAt])
  @@index([decision])
  @@index([strategyId])
}

/// Sector — first-class entity. Overton lives within a sector. Each
/// sector has its own cultural axis modelable as orientation tags +
/// dominant narratives + observed Overton state (snapshot + drift).
model Sector {
  id                 String    @id @default(cuid())
  slug               String    @unique
  name               String
  /// JSON describing the orientation tags (premium↔mass, traditional↔modern, etc.)
  culturalAxis       Json?
  /// Free-form list of dominant narratives currently shaping this sector
  dominantNarratives String[]
  /// JSON snapshot of the sector's Overton "center" — refreshed by Tarsis weekly
  overtonState       Json?
  /// Last refresh from Tarsis
  lastObservedAt     DateTime?
  countryCodes       String[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// CRDT doc for real-time collab on long-form pillar / Oracle text.
/// Phase 5 (NSP + Yjs). Stored as opaque BLOB; client reconciles via Yjs.
model StrategyDoc {
  id         String   @id @default(cuid())
  strategyId String
  docKind    String /// PILLAR_CONTENT | ORACLE_SECTION | MESTOR_CHAT
  docKey     String /// pillar key, section id, chat thread id
  yState     Bytes
  version    Int      @default(1)
  lastEditor String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([strategyId, docKind, docKey])
  @@index([strategyId])
}

/// Per-tier per-market price override.
/// Allows admins to adjust SPU values OR direct local-currency amounts
/// without code change. Falls back to monetization/pricing-tiers.ts SPU
/// when no override exists.
model PricingOverride {
  id           String    @id @default(cuid())
  tierKey      String /// PricingTierKey
  /// ISO-2 country code OR null for "global SPU override"
  countryCode  String?   @db.VarChar(2)
  /// Override SPU value (replaces the tier's amountSpu before market factor).
  /// If null, override is on amountLocal directly.
  amountSpu    Int?
  /// Override directly in local currency (skips market factor + FX).
  /// Used when the admin wants a specific price for a specific country
  /// (e.g. promo "29 EUR" or "5000 FCFA" override).
  amountLocal  Decimal?  @db.Decimal(12, 2)
  currencyCode String?   @db.VarChar(3)
  /// Whether this override is currently active.
  active       Boolean   @default(true)
  /// Optional reason for audit trail.
  reason       String?
  /// Optional expiration — auto-deactivate after this date.
  expiresAt    DateTime?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tierKey, countryCode])
  @@index([active])
  @@index([countryCode])
}

/// Provider configuration (non-secret) — let admins toggle providers,
/// set the standard country override, etc., without env var changes.
/// Secrets STAY in env vars (never in DB).
model PaymentProviderConfig {
  id         String   @id @default(cuid())
  /// CINETPAY | STRIPE | PAYPAL — provider this row configures.
  providerId String   @unique
  /// Whether the provider is allowed (admins can disable a provider
  /// without removing its env vars).
  enabled    Boolean  @default(true)
  /// Free-form non-secret JSON config (PAYPAL_ENV sandbox/live, etc.).
  config     Json?
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// ============================================================================
// PTAH FORGE (ADR-0009 — 5ème Neter)
// ============================================================================

/// GenerativeTask — un asset à matérialiser via Ptah.
/// Linéage : sourceIntentId pointe vers l'IntentEmission INVOKE_GLORY_TOOL
/// Artemis qui a produit le ForgeBrief. intentId pointe vers le
/// PTAH_MATERIALIZE_BRIEF correspondant.
model GenerativeTask {
  id                 String         @id @default(cuid())
  /// IntentEmission ID du PTAH_MATERIALIZE_BRIEF qui a déclenché cette task.
  intentId           String         @unique
  /// IntentEmission ID du INVOKE_GLORY_TOOL Artemis qui a produit le brief.
  sourceIntentId     String?
  /// Phase 10 (ADR-0012) — BrandAsset upstream (KV brief, big idea active, etc.)
  /// qui a déclenché cette forge. Lineage business complète.
  sourceBrandAssetId String?
  sourceBrandAsset   BrandAsset?    @relation(fields: [sourceBrandAssetId], references: [id])
  /// Si forge dans contexte campagne (lien direct sans passer par BrandAsset)
  campaignId         String?
  briefId            String?
  operatorId         String
  strategyId         String?
  /// image / video / audio / icon / refine / transform / classify / stock / design
  forgeKind          String
  /// magnific / adobe / figma / canva
  provider           String
  /// "mystic" / "kling-3" / "flux-2-pro" / "firefly-v3" / ...
  providerModel      String
  /// task_id retourné par le provider (Magnific) — null tant que pas créé.
  providerTaskId     String?
  /// CREATED / IN_PROGRESS / COMPLETED / FAILED / VETOED / EXPIRED
  status             String         @default("CREATED")
  /// sha256(prompt + params + provider + model) — clé de cache idempotente.
  promptHash         String
  parameters         Json
  /// Pillar ADVE/RTIS qui justifie cette forge — obligatoire (téléologie PANTHEON.md §2.5).
  pillarSource       String
  /// peddler / dealer / facilitator / entertainer
  manipulationMode   String
  /// URLs signées renvoyées par le provider (12h TTL Magnific).
  resultUrls         Json?
  estimatedCostUsd   Float
  realisedCostUsd    Float?
  /// Estimation bayésienne du potentiel superfan pre-flight.
  expectedSuperfans  Int?
  /// Mesuré par Seshat asset-impact-tracker post-déploiement.
  realisedSuperfans  Int?
  createdAt          DateTime       @default(now())
  completedAt        DateTime?
  /// Pour Magnific : createdAt + 12h. Cron download-before-expire.
  expiresAt          DateTime?
  /// Secret unique par task pour vérifier callback webhook (fail-closed).
  webhookSecret      String
  errorMessage       String?
  versions           AssetVersion[]

  @@index([operatorId, strategyId, forgeKind, status])
  @@index([promptHash])
  @@index([expiresAt])
  @@index([providerTaskId])
  @@index([sourceBrandAssetId])
  @@index([campaignId])
  @@index([briefId])
}

/// AssetVersion — version d'un asset, chaîne parent→upscale→relight.
model AssetVersion {
  id                     String          @id @default(cuid())
  parentAssetId          String?
  parent                 AssetVersion?   @relation("AssetLineage", fields: [parentAssetId], references: [id], onDelete: SetNull)
  children               AssetVersion[]  @relation("AssetLineage")
  generativeTaskId       String?
  generativeTask         GenerativeTask? @relation(fields: [generativeTaskId], references: [id], onDelete: SetNull)
  operatorId             String
  strategyId             String?
  /// image / video / audio / icon
  kind                   String
  /// URL provider d'origine (peut expirer).
  url                    String
  /// URL après download CDN (durable).
  cdnUrl                 String?
  width                  Int?
  height                 Int?
  durationMs             Int?
  fileSizeBytes          Int?
  metadata               Json
  /// cultIndexDelta mesuré par Seshat asset-impact-tracker.
  cultIndexDeltaObserved Float?
  createdAt              DateTime        @default(now())

  @@index([operatorId, strategyId])
  @@index([parentAssetId])
  @@index([generativeTaskId])
}

/// ForgeProviderHealth — état circuit breaker per-provider.
model ForgeProviderHealth {
  id             String    @id @default(cuid())
  /// magnific / adobe / figma / canva
  provider       String    @unique
  enabled        Boolean   @default(true)
  /// OPEN = circuit ouvert (provider hors-service), CLOSED = OK, HALF_OPEN = test.
  circuitState   String    @default("CLOSED")
  failureCount   Int       @default(0)
  lastFailureAt  DateTime?
  /// Reset auto à NOW + cooldown si circuitState = OPEN.
  circuitResetAt DateTime?
  lastSuccessAt  DateTime?
  totalRequests  Int       @default(0)
  totalFailures  Int       @default(0)
  totalCostUsd   Float     @default(0)
  updatedAt      DateTime  @updatedAt
}

// ============================================================================
// ERROR VAULT (Phase 11 — observabilité runtime)
// ============================================================================
// Collecteur centralisé d'erreurs serveur, client, Prisma, NSP, Ptah forge.
// Permet : debug post-mortem (sans logs externes), stress-test feedback,
// cleanup batch après refacto. Cf. EXPERT-PROTOCOL.md Phase 5.

enum ErrorSeverity {
  TRACE // info de debug seulement
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL // production-blocking
}

enum ErrorSource {
  SERVER // Next.js server route, tRPC handler, service
  CLIENT // React component, browser console.error
  PRISMA // DB query/migration
  NSP // Streaming protocol
  PTAH // Forge provider (Magnific/Adobe/Figma/Canva)
  STRESS_TEST // Émis par le stress-tester
  CRON // Cron jobs
  WEBHOOK // Webhook handler
  UNKNOWN
}

model ErrorEvent {
  id String @id @default(cuid())

  // Catégorisation
  source   ErrorSource   @default(UNKNOWN)
  severity ErrorSeverity @default(ERROR)
  /// Code court machine-lisible (ex: "ZOD_VALIDATION", "PTAH_PROVIDER_404",
  /// "MESTOR_VETO", "PRISMA_P2002", "NEXT_500", "CSP_VIOLATION").
  code     String?
  /// Message principal humain
  message  String

  // Contexte d'occurrence
  /// Stack trace si applicable (server-side ou Error.stack côté client)
  stack         String?
  /// Route HTTP / page concernée
  route         String?
  /// Session user (si dispo)
  userId        String?
  operatorId    String?
  strategyId    String?
  campaignId    String?
  /// IntentEmission lié si l'erreur s'est produite dans le dispatcher
  intentId      String?
  /// Procédure tRPC si applicable (ex: "campaign.create")
  trpcProcedure String?
  /// Component path si client (ex: "PtahForgeRunner")
  componentPath String?
  /// User agent client si applicable
  userAgent     String?

  // Déduplication
  /// sha256(source + code + message + stack[:500]) — clé de groupement
  signature   String
  /// Combien de fois cette signature a été vue (incrémenté par capture si même signature dans la dernière heure)
  occurrences Int      @default(1)
  /// Première occurrence (pour cluster, garde createdAt = lastSeenAt)
  firstSeenAt DateTime @default(now())
  /// Dernière occurrence
  lastSeenAt  DateTime @default(now())

  // Workflow de résolution
  /// Marqué résolu par operator → l'évier ne re-affiche plus jusqu'à nouvelle occurrence
  resolved           Boolean   @default(false)
  resolvedAt         DateTime?
  resolvedById       String?
  resolvedReason     String?
  /// Faux positif connu — auto-mark resolved sur futures occurrences
  knownFalsePositive Boolean   @default(false)

  // Données brutes additionnelles
  context Json?

  createdAt DateTime @default(now())

  @@index([signature, resolved])
  @@index([source, severity, resolved])
  @@index([operatorId, resolved])
  @@index([createdAt])
  @@index([lastSeenAt])
}

// ════════════════════════════════════════════════════════════════════
// PHASE 15 — ANUBIS COMMS (Ground #7) — full activation (ADR-0020)
// ════════════════════════════════════════════════════════════════════
//
// Anubis devient le 7ème Neter ACTIF. Cap APOGEE atteint (7/7).
//
// Anti-doublon NEFER §3 strict :
// - Notification + NotificationPreference + WebhookConfig + ExternalConnector
//   existent déjà → réutilisés.
// - 4 nouveaux models seulement : CommsPlan, BroadcastJob, EmailTemplate, SmsTemplate.
//
// Migration : `phase15-anubis-comms`. Strict `prisma migrate dev` (cf. CLAUDE.md).

/// Plan de communication global pour une stratégie/campagne.
/// Orchestré par Anubis. Cf. ADR-0020 §"Périmètre code Phase 15".
model CommsPlan {
  id           String    @id @default(cuid())
  strategyId   String
  campaignId   String?
  /// Mode d'engagement (cf. MANIPULATION-MATRIX) : peddler/dealer/facilitator/entertainer
  mode         String
  /// Canaux retenus (subset de NotificationChannel + ad-network types)
  channels     Json
  /// Audience JSON (rules ou audienceId résolu)
  audience     Json?
  /// Status workflow : DRAFT / SCHEDULED / ACTIVE / COMPLETED / CANCELLED
  status       String    @default("DRAFT")
  /// Date prévue de lancement
  scheduledFor DateTime?
  /// Operator créateur
  operatorId   String

  broadcastJobs BroadcastJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId])
  @@index([campaignId])
  @@index([status])
  @@index([operatorId])
}

/// Job de broadcast persistent (queue + retry + tracking).
/// Créé par ANUBIS_BROADCAST_MESSAGE / ANUBIS_SCHEDULE_BROADCAST.
model BroadcastJob {
  id             String    @id @default(cuid())
  commsPlanId    String
  /// Canal cible (email, sms, push, in-app, meta-ads, google-ads, x-ads, tiktok-ads)
  channel        String
  /// Payload de fan-out (subject/body/template_id/etc.)
  payload        Json
  /// Status : QUEUED / SCHEDULED / SENDING / SENT / FAILED / CANCELLED / DEFERRED
  status         String    @default("QUEUED")
  /// Si SCHEDULED, instant d'envoi prévu
  scheduledFor   DateTime?
  /// Provider task id retourné par le connector externe (Mailgun message-id, Meta ad-id, etc.)
  providerTaskId String?
  /// Tentatives envoyées
  attempts       Int       @default(0)
  /// Dernière erreur (si FAILED ou DEFERRED)
  errorLog       Json?
  /// Compteurs delivery (delivered/bounced/opened/clicked) — peuplés via ANUBIS_TRACK_DELIVERY
  metrics        Json?
  /// Operator déclencheur
  operatorId     String
  /// Lien IntentEmission origine (hash-chain Mestor)
  sourceIntentId String?

  commsPlan CommsPlan @relation(fields: [commsPlanId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sentAt    DateTime?

  @@index([commsPlanId])
  @@index([status])
  @@index([scheduledFor])
  @@index([operatorId])
}

/// Template email réutilisable. Peuplé par operator via Templates UI.
model EmailTemplate {
  id         String  @id @default(cuid())
  operatorId String
  name       String
  subject    String
  /// Body HTML (avec placeholders {{var}})
  htmlBody   String
  /// Body text fallback
  textBody   String?
  /// Variables attendues (pour validation au render)
  variables  Json?
  /// Catégorie : transactional / marketing / notification
  category   String  @default("transactional")
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operatorId, name])
  @@index([category, isActive])
}

/// Template SMS réutilisable.
model SmsTemplate {
  id         String  @id @default(cuid())
  operatorId String
  name       String
  /// Body text (max 160 chars idéalement, validé au render)
  body       String
  /// Variables attendues
  variables  Json?
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operatorId, name])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 18 — BRAND TREE multi-archétype (ADR-0052)
//
// Modèle d'arbre de marque générique qui se superpose à `Strategy` plat
// existant. Cascade canonique par BrandNature (cf. ADR-0054
// `BRAND_NATURE_ARCHETYPES`). Pour PRODUCT (FMCG) : 7 niveaux —
// CORPORATE → MASTER_BRAND → REGIONAL_CLUSTER → REGIONAL_BRAND →
// PRODUCT_LINE → PRODUCT_VARIANT → SKU.
//
// Migration legacy non-cassante : tous les Strategy existants deviennent
// `BrandNode { nodeKind: "STANDALONE_BRAND" }` orphelins via
// `scripts/backfill-brand-tree.ts` (idempotent, additif).
//
// Validation transitions parent → child : Mestor gate
// `NATURE_TRANSITION_VALIDITY` qui consulte `BRAND_NATURE_ARCHETYPES`.
// ═══════════════════════════════════════════════════════════════════

model BrandNode {
  id   String @id @default(cuid())
  name String
  /// Slug url-safe utilisé dans les routes /cockpit/portfolio/[slug]/...
  slug String

  // Tenancy & ownership business
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])
  /// Contrat business associé (FC, autre Client). null = nœud racine corporate
  /// pas encore rattaché à un contrat (ex: import portefeuille en cours).
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])

  // Tree structure
  parentNodeId String?
  parent       BrandNode?  @relation("BrandNodeTree", fields: [parentNodeId], references: [id])
  children     BrandNode[] @relation("BrandNodeTree")

  // Classification
  /// nodeKind libre, validé contre BRAND_NATURE_ARCHETYPES au runtime.
  /// Pour PRODUCT : CORPORATE | MASTER_BRAND | REGIONAL_CLUSTER | REGIONAL_BRAND |
  /// PRODUCT_LINE | PRODUCT_VARIANT | SKU | STANDALONE_BRAND (fallback backfill).
  nodeKind   String
  nodeNature BrandNature @default(PRODUCT)
  /// Tags orthogonaux : SEASONAL, LIMITED_EDITION, LICENSED, JV_PARTNER,
  /// LOCAL_VARIANT, PROMO_RAMADAN_2026, PROMO_BACK_TO_SCHOOL_2025, etc.
  nodeRole   String[]    @default([])

  // Inheritance & overrides (Phase 18 noyau cabling — Phase 18-A0 stocke seulement, ne résout pas encore)
  /// JSON des champs ADVE/RTIS overridés au niveau de ce nœud (vs hérités du parent)
  pillarOverrides   Json?
  /// Si true : enfants ne peuvent pas rompre certains champs (ex: tone-of-voice corporate)
  inheritanceLocked Boolean @default(false)

  // Geographic scope (when applicable)
  countryCode String? @db.VarChar(2)
  /// Cluster révélé par RAMADAN.xlsx : WESTERN_CLUSTER | TROPICAL_CLUSTER | ESA | custom
  clusterTag  String?

  // Lifecycle
  /// DRAFT | ACTIVE | PENDING_REGULATORY | ACQUIRED_INBOUND | DIVESTED | ARCHIVED | REVIVED
  lifecycle String @default("ACTIVE")

  // Phase 18-bis (M&A) — snapshot piliers résolus à la date de transfert ownership.
  pillarSnapshotAtTransfer Json?

  // Strangler link vers Strategy (legacy ou exploitation opérationnelle).
  /// Phase 18-A0 backfill : 1 BrandNode par Strategy existante avec
  /// nodeKind="STANDALONE_BRAND". Phase 18 noyau découpe ces standalone en
  /// arbre réel via wizard portfolio-bulk-import.
  strategyId String?
  strategy   Strategy? @relation(fields: [strategyId], references: [id])

  // Annexes (Phase 18-A0 fwd-decl, models en Phase 18-bis)
  // ownershipTransfersIn  NodeOwnershipTransfer[] @relation("NodeOwnershipIn")
  // ownershipTransfersOut NodeOwnershipTransfer[] @relation("NodeOwnershipOut")
  // partnershipsAsPrimary BrandPartnership[]      @relation("PartnershipPrimary")

  // Reverse relations
  deliverables      CampaignDeliverable[]
  clientAllocations ClientAllocation[]
  /// Phase 18-N3 — RAG context arborescent : BrandContextNode attachés à ce node.
  contextNodes      BrandContextNode[]    @relation("BrandNodeContextNodes")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@unique([operatorId, slug])
  @@index([operatorId, clientId])
  @@index([parentNodeId])
  @@index([nodeNature, clusterTag])
  @@index([countryCode])
  @@index([lifecycle])
  @@index([strategyId])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 18 — CAMPAIGN DELIVERABLE matrice 6D (ADR-0052)
//
// Granularité de production révélée par Checklist_Ramadan_2026_LISTE.xlsx
// (193 livrables Ramadan 2026 FC). Le `CampaignAction` existant (22 fields)
// ne capture pas la matrice {SKU × pack × promo × format × langue × pays}.
//
// 1 Campaign saisonnière = N CampaignDeliverable. Chaque deliverable cible
// un BrandNode (nodeKind=SKU ou PRODUCT_VARIANT typiquement) et matérialise
// optionnellement un BrandAsset (le visuel forgé Ptah).
// ═══════════════════════════════════════════════════════════════════

model CampaignDeliverable {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  /// SKU ou PRODUCT_VARIANT exact ciblé. Test anti-drift CI vérifie le nodeKind.
  targetNodeId String
  targetNode   BrandNode @relation(fields: [targetNodeId], references: [id])

  countryCode String? @db.VarChar(2)
  clusterTag  String?

  /// OOH_12M2 | POSTER_60x40 | POSM | TV_SPOT | RADIO_SPOT | BANDEROLE |
  /// WOBBLER | T_SHIRT | DIGITAL_AD | DIGITAL_POSTER | TABLE_SAMPLING | TG |
  /// PRESENTOIR | CHEVALET | LAMPOST | OUTDOOR | OOH_10M2 | OOH_18M2 | POSTER_60x80
  deliverableType String
  /// FR | EN | FR_EN
  language        String  @default("FR")
  /// PROMO_RAMADAN_2026 | PROMO_BACK_TO_SCHOOL_2025 | NON_PROMO | custom (10G_MORE_2026, etc.)
  promoTag        String?

  /// TODO | IN_PROGRESS | DELIVERED | VALIDATED
  status            String  @default("TODO")
  /// GREEN | AMBER | RED — calculé via computeRAG(deliverable) (status × deadline_proximity × blockers)
  rag               String  @default("GREEN")
  /// Override manuel par opérateur (computeRAG ignoré). Audit Mestor Intent OPERATOR_OVERRIDE_RAG.
  manualRagOverride String?

  /// Phase 18-A1-α — Code humain-readable format `[ID_PROJET].NN` (V4 sheet TÂCHES).
  /// Ex: `FC-TG-PEAK-001.03`. Auto-généré via `generateTaskCode()` ou fourni à l'import.
  /// Unique par campaign (même base ID_PROJET + index incrémental).
  taskCode String?

  /// Visuel forgé (Ptah AssetVersion → BrandAsset). Null tant que pas matérialisé.
  brandAssetId String?
  brandAsset   BrandAsset? @relation(fields: [brandAssetId], references: [id])

  /// Sous-traitance multi-agence (cas révélé par BACK2SCH "agence Ghana").
  delegatedToOperatorId String?
  delegatedToOperator   Operator? @relation("DeliverableDelegate", fields: [delegatedToOperatorId], references: [id])

  dueDate     DateTime?
  deliveredAt DateTime?
  validatedAt DateTime?

  /// Notes libres (briefs ad-hoc, contraintes techniques, retours client).
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 18-A1-β — Tickets de modification rattachés à ce livrable.
  changeRequests CampaignChangeRequest[]
  // NOTE Phase 18-A1-α : `@@unique([campaignId, taskCode])` souhaité mais reporté
  // pour éviter prompt interactif Prisma migrate dev en CI/agent. L'unicité est
  // assurée au niveau applicatif (helper `generateTaskCode()` + check avant insert).
  // À ajouter dans une migration dédiée Phase 18-A2.

  @@index([campaignId, status])
  @@index([targetNodeId])
  @@index([clusterTag, countryCode])
  @@index([rag])
  @@index([promoTag])
  @@index([deliverableType])
  @@index([delegatedToOperatorId])
  @@index([taskCode])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 18-A1-β — TICKETS MODIFS (ADR-0052 + audit MATANGA V4)
//
// Tracks les change requests client (= modifications demandées sur un livrable
// déjà produit ou en cours). Distinct de CampaignBrief.version (version d'un
// brief intellectuel) — ici c'est un ticket d'opération avec workflow
// PENDING → IN_PROGRESS → RESOLVED + impact COSMETIC/MINOR/MAJOR/OUT_OF_SCOPE
// + escalade Slack si MAJOR (cf. sheet PROTOCOLE ABSENCE V4).
//
// Format ticketCode : `[ID_TÂCHE]-R[NN]` (ex: `FC-TG-PEAK-001.03-R01`).
// Auto-généré via helper `generateChangeRequestCode()` from `src/domain/campaign-code.ts`.
// ═══════════════════════════════════════════════════════════════════

model CampaignChangeRequest {
  id         String @id @default(cuid())
  /// Format `[ID_TÂCHE]-R[NN]`, unique global. Auto-généré si non fourni.
  ticketCode String @unique

  campaignDeliverableId String
  deliverable           CampaignDeliverable @relation(fields: [campaignDeliverableId], references: [id])

  /// Nom libre du demandeur (client externe ou opérateur interne). Pas une FK User
  /// car certains demandeurs (ex: Estelle NGAMGO chez Cadyst) sont des contacts
  /// externes pas dans la table User.
  requestedByName String
  requestedAt     DateTime @default(now())
  /// Description libre de la modif demandée.
  description     String

  impact ChangeRequestImpact
  status ChangeRequestStatus @default(PENDING)

  /// Si assigné à un operator interne (TalentProfile.userId existant).
  assignedToUserId String?
  assignedToUser   User?   @relation("ChangeRequestAssignee", fields: [assignedToUserId], references: [id])

  resolvedAt      DateTime?
  resolutionNotes String?

  /// Si la modif a engendré une nouvelle version de brief (CampaignBrief.version+1).
  newBriefVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignDeliverableId, status])
  @@index([impact])
  @@index([assignedToUserId])
  @@index([requestedAt])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 18-A1-γ — OPERATOR ACTIONS (ADR-0052 + audit MATANGA V4)
//
// Sub-tâches transverses jour-le-jour qui ne sont PAS des CampaignDeliverable
// directes (= produire un visuel) ni des Mission (= cycle Glory tool). Capturent
// les "AVANT DÉPART", "RELANCES", "PRODUCTION setup", "SYSTÈME" du V4.
//
// Lien optionnel vers Campaign + multi-deliverables (ex: "Produire les 8
// sous-briefs pour FC-TG-PEAK-001 .01 .02 .03 .04 .05 .06 .07 .08").
// ═══════════════════════════════════════════════════════════════════

model OperatorAction {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation("OperatorActions", fields: [operatorId], references: [id])

  label   String
  context String?

  priority OperationalPriority    @default(MOYENNE)
  category OperatorActionCategory @default(OTHER)
  source   OperatorActionSource   @default(OTHER)

  /// Si rattaché à un projet, lien vers Campaign.
  campaignId     String?
  campaign       Campaign? @relation("CampaignOperatorActions", fields: [campaignId], references: [id])
  /// Multi-deliverables linkés (ex: ".01,.02,.03,.04" du V4 sheet ACTIONS).
  /// String[] pour conserver l'ordre + éviter table join supplémentaire.
  deliverableIds String[]  @default([])

  /// Assignation optionnelle à un opérateur interne.
  assigneeUserId String?
  assignee       User?   @relation("OperatorActionAssignee", fields: [assigneeUserId], references: [id])

  done    Boolean   @default(false)
  doneAt  DateTime?
  dueDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId, done])
  @@index([priority])
  @@index([category])
  @@index([campaignId])
  @@index([assigneeUserId])
  @@index([dueDate])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 18-A1-δ — MORNING BRIEF BATCH (ADR-0055 + audit MATANGA V4 SIGNAUX)
//
// Cadence quotidienne d'ingestion mail/slack/whatsapp avec middle portal
// validation humaine. La sheet SIGNAUX V4 (32 rows manuelles) est
// remplacée nativement par ces 3 modèles + service `morning-batch`.
//
// Flow :
//   1. Operator paste blob OU auto-pull (Phase 18-A2)
//   2. Splitter LLM → N IngestedSource
//   3. Extractor LLM → 0..N BriefIngestionDraft per source
//   4. Reconciler classify NEW/UPDATE/NON_BRIEF/OPS/AMBIGUOUS + match BrandNode
//   5. Middle portal UI → operator validate/edit/reject row par row
//   6. Confirm batch → matérialisation via mestor.emitIntent (Manual-first
//      parity ADR-0053 — mêmes endpoints qu'une saisie manuelle)
// ═══════════════════════════════════════════════════════════════════

model IngestedSource {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation("OperatorIngestedSources", fields: [operatorId], references: [id])

  kind IngestedSourceKind

  /// Gmail msg id, Slack ts, WhatsApp msg id (pour dedup cross-batches).
  externalId String?
  /// Lien cliquable vers le mail/slack original (audit/provenance UI).
  sourceUrl  String?
  /// From: email ou Slack user.
  sender     String?
  /// Subject mail / channel slack.
  subject    String?

  /// Contenu brut (PII redacted par pii-redactor.ts avant stockage).
  rawSnippet     String   @db.Text
  /// Tag des champs PII redactés (audit transparence).
  redactedFields String[] @default([])

  /// Pour grouper threads mail (Message-ID parent) / Slack threads (thread_ts).
  threadKey String?
  /// FR | EN | FR_EN | autre — détecté par splitter LLM.
  language  String?

  ingestedAt DateTime @default(now())

  briefIngestions        BriefIngestionDraft[]
  // Phase 18-A1-δ — Reverse relation pour provenance chain CampaignBrief.
  campaignBriefsFromHere CampaignBrief[]       @relation("CampaignBriefSource")

  @@index([operatorId, ingestedAt])
  @@index([threadKey])
  @@index([kind, externalId]) // pour dedup
}

model MorningBriefBatch {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation("OperatorMorningBatches", fields: [operatorId], references: [id])

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  /// Le blob raw collé par l'opérateur OU concaténation auto-pull.
  rawInput    String @db.Text
  sourceCount Int    @default(0)
  briefCount  Int    @default(0)

  state MorningBriefBatchState @default(ANALYZING)

  // Stats LLM (audit cost + accuracy ML)
  llmConfidenceMean Float?
  llmTotalTokens    Int?
  llmCostUsd        Float?

  drafts BriefIngestionDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId, startedAt])
  @@index([state])
}

model BriefIngestionDraft {
  id       String            @id @default(cuid())
  batchId  String
  batch    MorningBriefBatch @relation(fields: [batchId], references: [id])
  sourceId String
  source   IngestedSource    @relation(fields: [sourceId], references: [id])

  extractedAt DateTime @default(now())

  classification       BriefIngestionClassification
  /// Justification reconciler (ex: "positive feedback, not actionable" pour NON_BRIEF).
  classificationReason String?

  // Matching résultats (peuvent être null si AMBIGUOUS ou NON_BRIEF)
  resolvedNodeId       String?
  resolvedNodePath     String[] @default([])
  resolvedCampaignId   String?
  resolvedCampaignName String?

  /// Contenu structuré du brief extrait :
  /// { title, summary, briefType, urgency, deadline, deliverables[], notes }
  payload    Json
  /// Confidence LLM 0..1 (drives auto-confirm threshold Phase 2 fine-tune).
  confidence Float @default(0.0)

  state       BriefIngestionDraftState @default(PENDING_REVIEW)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  // Materialization trace
  materializedCampaignBriefId String?
  materializedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId, state])
  @@index([classification])
  @@index([resolvedNodeId])
  @@index([resolvedCampaignId])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 18 RÉSIDUS — Formulaire opérateur de session future
//
// Les paliers N5-bis (Bible reclassif manuelle ~300 entrées), N6-bis (56 Glory
// tools annotation), N9 (script duplicate-pillars), N10 (feature flag rollout),
// LLM Phase 2 fine-tune, Cache Redis et Phase 18-bis (M&A) sont tous reportés.
//
// Plutôt que de les dérouler en autonomie NEFER (ils sont domain-business ou
// nécessitent des décisions opérateur ad-hoc), ils sont **mis en attente derrière
// un formulaire** que l'opérateur remplit lors d'une future session :
// `/console/governance/phase-18-residuals`.
//
// Chaque réponse opérateur est persistée comme `Phase18ResidualEntry` qui sert
// d'audit trail + de point de reprise pour NEFER (cf. memory user
// phase_18_residuals_pending.md + RESIDUAL-DEBT.md §Phase 18).
// ═══════════════════════════════════════════════════════════════════

model Phase18ResidualEntry {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation("OperatorPhase18Residuals", fields: [operatorId], references: [id])

  category  Phase18ResidualCategory
  /// Clé cible de cette entrée (sémantique dépendante de category) :
  ///   - BIBLE_VAR        : "BIBLE_A.tone" / "BIBLE_E.shopper-journey" / etc.
  ///   - GLORY_TOOL       : slug du tool (ex: "creative-brief", "writers-room")
  ///   - PILLAR_DUPLICATE : nodeId source détecté
  ///   - FEATURE_FLAG     : nom du flag (ex: "BRAND_TREE_INHERITANCE_ENABLED")
  ///   - LLM_TUNING       : "extractor" | "classifier" | "narrative-coherence"
  ///   - PHASE_18_BIS     : "M&A" | "CHARACTER_IP" | "MEDIA_IP" | etc.
  ///   - CACHE_INFRA      : "REDIS_MIGRATION"
  targetKey String

  /// Payload structuré spécifique à la category :
  ///   - BIBLE_VAR : { applicableNatures: BrandNature[], inheritanceMode, notes }
  ///   - GLORY_TOOL : { applicableNatures: BrandNature[] }
  ///   - PILLAR_DUPLICATE : { duplicateNodeIds: string[], propagateFromAncestor: bool }
  ///   - FEATURE_FLAG : { enabled: bool, scope: "OPERATOR" | "GLOBAL" }
  ///   - LLM_TUNING : { promptDraft: string, accuracyTarget: number }
  ///   - PHASE_18_BIS : { archetype: BrandNature, priorityRank: number }
  ///   - CACHE_INFRA : { redisUrl: string?, ttlSeconds: number }
  payload Json

  status Phase18ResidualStatus @default(PENDING)

  /// Notes opérateur libres (justification, contexte, lien Slack/Notion, etc.).
  notes String?

  resolvedAt DateTime?
  resolvedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operatorId, category, targetKey])
  @@index([operatorId, status])
  @@index([category, status])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 21 (ADR-0068) — OracleSection first-class entity
// ═══════════════════════════════════════════════════════════════════
//
// 35 sections × strategyId. Lifecycle PENDING → GENERATING → COMPLETE
// → FAILED → STALE. Permet :
//   - Génération manuelle par section (bouton individuel UI)
//   - Assembler comme orchestrator manual-first (boucle sur sections)
//   - Progress streaming par section via NSP SSE
//   - Stale tracking quand piliers ADVE mutent
//
// Cf. CLAUDE.md §Phase 21 + ADR-0068. Sub-domaine ARTEMIS, Cap APOGEE 7/7
// préservé.
// ═══════════════════════════════════════════════════════════════════

enum OracleTier {
  CORE
  BIG4_BASELINE
  DISTINCTIVE
}

enum OracleSectionStatus {
  PENDING // jamais générée
  GENERATING // génération en cours (lock détenu)
  COMPLETE // payload validé Zod, confidence calculée
  FAILED // échec après retry — lastError peuplé
  STALE // payload existant mais piliers source ont muté
}

model OracleSection {
  id                        String              @id @default(cuid())
  strategyId                String
  /// Numéro de section 1..35 (cf. SECTION_REGISTRY src/server/services/strategy-presentation/types.ts).
  sectionId                 Int
  /// Tier framework canonical (CORE/BIG4_BASELINE/DISTINCTIVE).
  tier                      OracleTier
  /// État machine — voir enum doc.
  status                    OracleSectionStatus @default(PENDING)
  /// Payload validé Zod (shape selon section.runner.outputSchema). Null tant
  /// que pas COMPLETE.
  payload                   Json?
  /// Confidence 0..1 calculée par le runner (Glory sequence ou framework).
  confidence                Float?
  /// Timestamp début de la dernière génération (transition → GENERATING).
  lastGenerationStartedAt   DateTime?
  /// Timestamp fin de la dernière génération réussie (transition → COMPLETE).
  lastGenerationCompletedAt DateTime?
  /// Erreur structurée { errorCode, errorMessage, attempts, zodIssues? }.
  lastError                 Json?
  /// Code d'erreur normalisé (ex: ZOD_VALIDATION_FAILED, LLM_CALL_FAILED, INPUTS_NOT_READY).
  errorCode                 String?
  /// Compteur cumulatif des tentatives de génération (jamais reset).
  generationCount           Int                 @default(0)
  /// Concurrency control — incrément à chaque write payload.
  version                   Int                 @default(1)
  /// Marqueur stale — setté quand un pilier ADVE source mute (cascade).
  staleAt                   DateTime?
  /// Lock optimistic — token aléatoire détenu pendant GENERATING.
  lockToken                 String?
  /// Expiration du lock (TTL ~25s default = SLO p95 + marge).
  lockExpiresAt             DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([strategyId, sectionId])
  @@index([strategyId, status])
  @@index([strategyId, tier])
  @@index([staleAt])
}
