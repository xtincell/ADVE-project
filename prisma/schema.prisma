// Phase 10 (ADR-0012) — BrandAsset state machine
enum BrandAssetState {
  DRAFT // En cours de création par séquence
  CANDIDATE // Un parmi N proposés (avant sélection)
  SELECTED // Sélectionné parmi candidats
  ACTIVE // Version courante en usage par la marque/campagne
  SUPERSEDED // Remplacé par une version plus récente (lineage préservée)
  ARCHIVED // Mort rituel — lecture seule
  REJECTED // Rejeté lors de la sélection (lineage préservée)
}

/// BrandAsset = vault de la marque, réceptacle unique pour TOUS les actifs.
///
/// Couvre deux familles :
///  - Actifs **intellectuels** (content Json, fileUrl null) : Big Idea,
///    Brief créatif, Brainstorm, Claim, Manifeste, Concept, Naming, KV brief,
///    Tone Charter, Persona, Superfan Journey, Brief 360°, etc.
///  - Actifs **matériels** (fileUrl rempli) : KV image (Ptah forgé Nano Banana),
///    spot vidéo, jingle audio, packaging, OOH, logo final, etc.
///
/// Cycle de vie : DRAFT → CANDIDATE → SELECTED → ACTIVE → SUPERSEDED.
/// Sélection parmi N candidats par batch. Supersession = nouvelle version
/// remplace ACTIVE. Lineage hash-chain via sourceIntentId (Mestor).
///
/// Les Glory tools brief-only déposent automatiquement dans le vault via
/// sequence-executor. Les forges Ptah promeuvent leurs AssetVersion en
/// BrandAsset matériel via chainGloryToPtah.
///
/// Cf. PANTHEON.md (Phase 10), LEXICON.md, ADR-0012.
model BrandAsset {
  id String @id @default(cuid())

  // Identité
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id])
  name       String

  // Catégorisation Phase 10 — taxonomie complète des actifs de marque
  /// Source de vérité TS : src/domain/brand-asset-kinds.ts (BrandAssetKind enum).
  ///
  /// Phase 10 baseline : BIG_IDEA / CREATIVE_BRIEF / BRIEF_360 / BRAINSTORM / CONCEPT /
  /// CLAIM / MANIFESTO / NAMING / POSITIONING / TONE_CHARTER / PERSONA /
  /// SUPERFAN_JOURNEY / KV_ART_DIRECTION_BRIEF / KV_VISUAL / KV_PROMPT /
  /// SCRIPT / STORYBOARD / DIALOGUE / SOUND_BRIEF / VOICEOVER_BRIEF /
  /// CASTING_BRIEF / VENDOR_BRIEF / PRINT_AD_SPEC / SOCIAL_COPY / RADIO_COPY /
  /// LONG_COPY / VALUE_PROPOSITION / PITCH / CHROMATIC_STRATEGY /
  /// TYPOGRAPHY_SYSTEM / LOGO_IDEA / LOGO_FINAL / VIDEO_SPOT / AUDIO_JINGLE /
  /// PACKAGING_LAYOUT / OOH_LAYOUT / TREND_RADAR / SEO_REPORT / GENERIC.
  ///
  /// Phase 13 extension Oracle 35-section (ADR-0015) :
  /// MCK_7S / BCG_PORTFOLIO / BAIN_NPS / MCK_3H / BCG_STRATEGY_PALETTE /
  /// DELOITTE_GREENHOUSE / DELOITTE_BUDGET (Big4 baseline) +
  /// CULT_INDEX / MANIPULATION_MATRIX / OVERTON_WINDOW (distinctifs Oracle).
  kind   String  @default("GENERIC")
  /// outputFormat original Glory tool si applicable
  format String?
  /// INTELLECTUAL (content seul) | MATERIAL (fileUrl) | HYBRID
  family String  @default("HYBRID")
  /// Visibilité — system / operator / production (legacy)
  level  String  @default("production")

  // Payload
  /// Actif intellectuel : payload structuré (output Glory tool, brief, etc.)
  content  Json?
  /// Actif matériel : URL fichier
  fileUrl  String?
  mimeType String?
  fileSize Int?
  /// Texte court pour listing UI
  summary  String?

  // Cycle de vie gouverné
  state BrandAssetState @default(DRAFT)

  // Téléologie
  pillarTags       Json? // legacy : { "a": 0.8, ... } scoring
  /// Phase 10 — pillar source canonique uppercase
  pillarSource     String? // A / D / V / E / R / T / I / S
  /// Phase 10 — manipulation mode visé
  manipulationMode String? // peddler / dealer / facilitator / entertainer

  // Lineage upstream
  sourceExecutionId    String?
  execution            SequenceExecution? @relation(fields: [sourceExecutionId], references: [id])
  /// IntentEmission INVOKE_GLORY_TOOL (hash-chain Mestor)
  sourceIntentId       String?
  /// GloryOutput row (log brut origine)
  sourceGloryOutputId  String?
  /// AssetVersion (Phase 9 Ptah) si actif matériel forgé
  sourceAssetVersionId String?
  /// Group ID si batch de N candidats
  batchId              String?
  batchSize            Int                @default(1)
  batchIndex           Int                @default(0)

  // Lineage business
  campaignId String?
  campaign   Campaign?      @relation(fields: [campaignId], references: [id])
  briefId    String?
  brief      CampaignBrief? @relation(fields: [briefId], references: [id])

  // Sélection
  selectedAt     DateTime?
  selectedById   String?
  selectedReason String?

  // Versioning
  version            Int          @default(1)
  parentBrandAssetId String?
  parent             BrandAsset?  @relation("BrandAssetVersion", fields: [parentBrandAssetId], references: [id])
  children           BrandAsset[] @relation("BrandAssetVersion")

  // Supersession
  supersededById    String?
  supersededByAsset BrandAsset?  @relation("BrandAssetSupersede", fields: [supersededById], references: [id])
  supersedes        BrandAsset[] @relation("BrandAssetSupersede")
  supersededAt      DateTime?
  supersededReason  String?

  // Liens downstream (forges Ptah qui partent de ce BrandAsset)
  generativeTasks GenerativeTask[]

  // Phase 18 (ADR-0059) — CampaignDeliverable matérialisés à partir de ce BrandAsset.
  // Cas d'usage : 1 KV BrandAsset (kind=KV_VISUAL) sert N CampaignDeliverable (1 par pays/format/langue).
  deliverables CampaignDeliverable[]

  // Multi-tenant
  operatorId String?

  metadata Json?

  // Phase ADR-0023 — staleness flag set when a source pillar is amended via
  // OPERATOR_AMEND_PILLAR (STRATEGIC_REWRITE mode). The asset stays ACTIVE
  // (sémantique enum préservée) but operators see a "regen suggested" badge.
  // Cleared when a successor SUPERSEDES this asset, or by explicit ack.
  staleAt     DateTime?
  staleReason String?

  // Legacy
  assetType String? // DEPRECATED — utiliser kind

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId, kind, state])
  @@index([campaignId, kind, state])
  @@index([briefId])
  @@index([batchId])
  @@index([parentBrandAssetId])
  @@index([staleAt])
  @@index([sourceIntentId])
  @@index([sourceGloryOutputId])
  @@index([sourceAssetVersionId])
  @@index([state])
  @@index([operatorId])
}

model Pillar {
  id               String    @id @default(cuid())
  strategyId       String
  key              String
  content          Json?
  confidence       Float?
  validationStatus String    @default("DRAFT") // DRAFT, AI_PROPOSED, VALIDATED, LOCKED
  staleAt          DateTime? // Set when pillar is marked stale; cleared on content update
  sources          Json? // [{ sourceId, sourceType, field, confidence }]
  pendingRecos     Json? // DEPRECATED — migrated to Recommendation table. Kept for backward compat.
  commentary       Json? // { fieldName: "operator commentary text", ... } — qualitative justification per field
  completionLevel  String? // INCOMPLET|COMPLET|FULL — cached, updated after each applyRecos
  /// PR-C (ADR-0035) — per-field certainty tracking. Mapping
  /// { fieldPath: SourceCertainty } — see src/domain/source-certainty.ts.
  /// Populated at activateBrand time by the LLM inference pass for needsHuman
  /// fields (certainty=INFERRED). Operator can flip a field to DECLARED via
  /// pillar.confirmInferredField mutation. Distinct from BrandDataSource.certainty
  /// (source-level) — this is the field-level granularity needed by the
  /// "Champs à valider" panel and downstream forges (Notoria gating).
  fieldCertainty   Json?

  currentVersion Int @default(1)

  strategy Strategy        @relation(fields: [strategyId], references: [id])
  versions PillarVersion[]

  tenantId String? // v4 — multi-tenant RLS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyId, key])
  @@index([tenantId])
}

model PillarVersion {
  id       String  @id @default(cuid())
  pillarId String
  version  Int
  content  Json
  diff     Json?
  author   String?
  reason   String?

  pillar Pillar @relation(fields: [pillarId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([pillarId])
  @@index([createdAt])
}

model BrandDataSource {
  id               String  @id @default(cuid())
  strategyId       String
  sourceType       String // FILE, CRM_SYNC, MANUAL_INPUT, URL
  fileName         String?
  fileType         String? // PDF, DOCX, XLSX, IMG, CSV, TXT, JSON
  rawContent       String? @db.Text // texte extrait
  rawData          Json? // données structurées
  processingStatus String  @default("PENDING") // PENDING, EXTRACTING, EXTRACTED, PROCESSING, PROCESSED, FAILED
  extractedFields  Json? // champs détectés par l'extracteur
  pillarMapping    Json? // { a: true, d: true, ... }
  errorMessage     String?

  /// Niveau de certitude opérateur — taxonomie src/domain/source-certainty.ts.
  /// OFFICIAL : pièce officielle uploadée (KBIS, contrat, deck investor) — vérifié.
  /// DECLARED : déclaré par fondateur/opérateur (intake, saisie manuelle) — non vérifié.
  /// INFERRED : extrait IA depuis texte libre / OCR (responses[*] hallucinables).
  /// ARBITRARY : décrété sans source (placeholder, hypothèse de travail).
  /// Default DECLARED — bascule la précédente assomption "tout est extrait" vers
  /// "tout est déclaré sauf preuve du contraire". Override via ingestion.updateSource.
  certainty String @default("DECLARED")

  /// Origine canonique de la source (anti-doublon ADR-0032). Permet à
  /// `INTAKE_SOURCE_PURGE_AND_REINGEST` de retrouver la source intake à purger
  /// sans heuristique sur fileName/sourceType. Format : "intake:<intakeId>",
  /// "manual:<userId>", "upload:<sha256>", etc.
  origin String?

  strategy Strategy @relation(fields: [strategyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId])
  @@index([processingStatus])
  @@index([certainty])
  @@index([origin])
}

