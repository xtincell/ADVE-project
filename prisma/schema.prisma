// Phase 18-A1 (ADR-0059 + audit MATANGA V4) — Aligné sur les 5 statuts officiels
// V4 (sheet REGISTRE PROJETS). Strangler du champ String libre `creativeState` shippé
// Phase 18-A0. Le 6e statut V4 (🔴 CRITIQUE) est modélisé orthogonalement via flag
// `Campaign.isCritical: Boolean` (peut être TRUE concurremment à n'importe quel
// CreativeProductionStatus — un projet en cours peut devenir critique).
enum CreativeProductionStatus {
  BRIEF_RECU // 📥 brief reçu, pas encore qualifié
  BRIEF_QUALIFIE // 📋 brief qualifié, direction posée
  EN_PRODUCTION // 🎨 en production active
  BLOQUE // ⏸️ bloqué (attente client / brief / cahier des charges / packaging)
  LIVRE // ✅ livré (peut encore avoir tickets modifs en cours)
}

// Phase 18-A1 — Workflow client miroir, aligné V4 (BACK2SCH STATUT client column).
enum ClientReviewStatus {
  PENDING
  BRAINSTORMING
  EN_ATTENTE_FEEDBACK
  RETOUR_RECU
  TOOL_KIT_A_EXECUTER
  EN_ATTENTE_PACKAGING
  VALIDE
  REJETE
}

// Phase 18-A1 — Priorité opérationnelle (sheet ACTIONS V4).
enum OperationalPriority {
  CRITIQUE
  HAUTE
  MOYENNE
  BASSE
}

// Phase 18-A1-β (audit MATANGA V4 sheet TICKETS MODIFS) — Impact d'une demande
// de modification client. Détermine le workflow d'escalade (cf. PROTOCOLE ABSENCE) :
// COSMETIC → traiter directement | MINOR → ticket + traiter si direction claire |
// MAJOR → STOP + escalade | OUT_OF_SCOPE → refuser poliment + Nelson.
enum ChangeRequestImpact {
  COSMETIC
  MINOR
  MAJOR
  OUT_OF_SCOPE
}

// Phase 18-A1-β — État d'un ticket de modif.
enum ChangeRequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
  ESCALATED
}

// Phase 18-A1-γ (audit MATANGA V4 sheet ACTIONS) — Catégorie d'action opérationnelle
// transverse. Différent d'ActionCategory (ATL/BTL/TTL) qui qualifie un canal pub.
enum OperatorActionCategory {
  BEFORE_DEPARTURE
  SYSTEM
  FOLLOWUPS
  PRODUCTION
  OTHER
}

// Phase 18-A1-γ — Source de signalement d'une action (sheet ACTIONS V4 colonne SOURCE).
enum OperatorActionSource {
  GMAIL
  SLACK
  WHATSAPP
  VERBAL
  BRIEF
  SYSTEM
  OTHER
}

// Phase 18 résidus — catégories de réponses opérateur via formulaire de session future
// (cf. /console/governance/phase-18-residuals).
enum Phase18ResidualCategory {
  /// N5-bis — Variable Bible reclassif manuelle (~300 entrées × 9 natures × 3 modes).
  BIBLE_VAR
  /// N6-bis — Annotation manuelle 56 Glory tools (`applicableNatures`).
  GLORY_TOOL
  /// N9 — Décision sur duplicate piliers détectés (BR-CI/SN/NG → BR Global inheritance).
  PILLAR_DUPLICATE
  /// N10 — Activation/désactivation feature flag global rollout.
  FEATURE_FLAG
  /// LLM Phase 2 — Trigger fine-tune extractor / classifier / coherence-gate.
  LLM_TUNING
  /// Phase 18-bis — M&A NodeOwnershipTransfer + 8 archétypes non-PRODUCT.
  PHASE_18_BIS
  /// Cache Redis cross-process.
  CACHE_INFRA
}

enum Phase18ResidualStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

// Phase 18-A1-δ (ADR-0062 — audit MATANGA V4 sheet SIGNAUX) — Type de source ingérée
// dans le Morning Brief Batch. EMAIL/SLACK/WHATSAPP via Anubis MCP entrant
// (Phase 18-A2 auto-pull) ou paste manuel ; FILE_UPLOAD pour PDF/docx/image briefs.
enum IngestedSourceKind {
  EMAIL
  SLACK
  WHATSAPP
  MANUAL_PASTE
  FILE_UPLOAD
}

// Phase 18-A1-δ — État d'un MorningBriefBatch.
enum MorningBriefBatchState {
  ANALYZING
  READY_FOR_REVIEW
  PARTIAL_VALIDATED
  FULLY_VALIDATED
  DISCARDED
}

// Phase 18-A1-δ — Classification d'un BriefIngestionDraft par le reconciliation engine.
// Permet l'aiguillage à matérialisation : NEW_BRIEF → nouvelle Campaign+Brief ;
// UPDATE_OF_BRIEF → patch Campaign existant ; NON_BRIEF → archivé en source seule ;
// OPS_ACTION → matérialisé en OperatorAction (Phase 18-A1-γ) ; AMBIGUOUS → human pick.
enum BriefIngestionClassification {
  NEW_BRIEF
  UPDATE_OF_BRIEF
  NON_BRIEF
  OPS_ACTION
  AMBIGUOUS
}

// Phase 18-A1-δ — Workflow staging d'un BriefIngestionDraft.
enum BriefIngestionDraftState {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
  EDITED
  MATERIALIZED
  AUTO_MATERIALIZED
}

