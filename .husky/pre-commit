#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Phase 0 — fast checks only. Heavier audit runs in CI.
echo "→ husky/pre-commit: governance lint (lafusee plugin)"
npx --no -- eslint --config eslint.config.mjs --no-warn-ignored \
  $(git diff --cached --name-only --diff-filter=ACMR | grep -E '^src/.*\.(ts|tsx)$' | tr '\n' ' ') \
  || { echo "✗ pre-commit blocked by lafusee/* rules"; exit 1; }
