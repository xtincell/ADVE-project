// La Fusée v7 — schéma tranche 1 (fondations).
// Doctrine : le schéma grandit PAR TRANCHES avec les WP de port (docs/REBUILD-PLAN.md §5),
// migrations additives uniquement. Postgres sur Coolify ; URL via driver adapter
// (@prisma/adapter-pg) instancié côté serveur — jamais d'url dans ce fichier.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ————— Identité & tenancy (1 app, 3 espaces par rôle — plus de portails séparés) —————

enum WorkspaceKind {
  AGENCY // UPgraders et agences partenaires
  BRAND // espace d'une marque cliente
}

enum MemberRole {
  OWNER
  OPERATOR // opérateur agence
  MEMBER // collaborateur
  CLIENT // fondateur / payeur
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

model Workspace {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  kind          WorkspaceKind
  createdAt     DateTime       @default(now())
  memberships   Membership[]
  brands        Brand[]
  subscriptions Subscription[]
  payments      Payment[]
}

model Membership {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String
  role        MemberRole
  user        User       @relation(fields: [userId], references: [id])
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

// ————— Marque & méthode (le cœur : cascade ADVE → RTIS, paliers) —————

enum BrandLevel {
  LATENT
  FRAGILE
  ORDINAIRE
  FORTE
  CULTE
  ICONE
}

enum PillarKey {
  A
  D
  V
  E
  R
  T
  I
  S
}

model Brand {
  id           String        @id @default(cuid())
  workspaceId  String
  slug         String
  name         String
  sector       String?
  countryCode  String?
  level        BrandLevel    @default(LATENT)
  createdAt    DateTime      @default(now())
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  country      Country?      @relation(fields: [countryCode], references: [code])
  pillars      Pillar[]
  scores       BrandScore[]
  deliverables Deliverable[]

  @@unique([workspaceId, slug])
}

model Pillar {
  id        String           @id @default(cuid())
  brandId   String
  key       PillarKey
  content   Json // champs du pilier (validés Zod côté serveur, source : variable bible)
  certainty Json? // fieldCertainty : INFERRED (draft IA) vs DECLARED (validé opérateur)
  version   Int              @default(1)
  updatedAt DateTime         @updatedAt
  brand     Brand            @relation(fields: [brandId], references: [id])
  revisions PillarRevision[]

  @@unique([brandId, key])
}

// Append-only : toute écriture de pilier laisse une révision (l'audit de la méthode).
model PillarRevision {
  id        String   @id @default(cuid())
  pillarId  String
  version   Int
  content   Json
  reason    String // intake | operator_amend | rtis_refresh | import
  actorId   String?
  createdAt DateTime @default(now())
  prevHash  String?
  selfHash  String?
  pillar    Pillar   @relation(fields: [pillarId], references: [id])

  @@index([pillarId, version])
}

model BrandScore {
  id         String     @id @default(cuid())
  brandId    String
  total      Float // /200, agrégat des dimensions (moteur déterministe porté du legacy)
  dimensions Json // breakdown par dimension — traçabilité complète
  level      BrandLevel
  computedAt DateTime   @default(now())
  brand      Brand      @relation(fields: [brandId], references: [id])

  @@index([brandId, computedAt])
}

// ————— Livrables (l'Oracle = un kind parmi N ; composition déterministe d'abord) —————

enum DeliverableStatus {
  DRAFT
  GENERATING
  READY
  STALE
  ARCHIVED
}

model Deliverable {
  id         String            @id @default(cuid())
  brandId    String
  kind       String // oracle | brief | manifesto | kv | ... (registre en code)
  title      String
  status     DeliverableStatus @default(DRAFT)
  content    Json?
  composedAt DateTime?
  createdAt  DateTime          @default(now())
  brand      Brand             @relation(fields: [brandId], references: [id])

  @@index([brandId, kind])
}

// ————— Funnel public (point d'entrée n°1 de la valeur) —————

enum LeadStatus {
  NEW
  QUALIFIED
  CONVERTED
  ARCHIVED
}

model IntakeLead {
  id        String     @id @default(cuid())
  email     String
  brandName String
  payload   Json // réponses du funnel — nourrit le seed ADVE à la conversion
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())

  @@index([status, createdAt])
}

// ————— Facturation (mobile money d'abord ; validation manuelle assumée en V1) —————

model Subscription {
  id          String    @id @default(cuid())
  workspaceId String
  plan        String
  status      String // pending_manual | active | expired | cancelled
  provider    String // wave | orange | mtn | moov | manual_whatsapp | stripe
  startedAt   DateTime  @default(now())
  expiresAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, status])
}

model Payment {
  id          String    @id @default(cuid())
  workspaceId String
  amount      Int // en unité mineure de currency
  currency    String // XOF | XAF | EUR ...
  method      String
  status      String
  reference   String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
}

// ————— Référentiel marché (tables seedées — jamais de barème en dur dans le code) —————

model Country {
  code     String  @id // ISO-3166 alpha-2
  name     String
  currency String
  zone     String? // UEMOA | CEMAC | ...
  brands   Brand[]
}

model ZoneIndex {
  id          String    @id @default(cuid())
  family      String // cost-of-living | forex | tjm | taxes | ...
  countryCode String
  key         String
  value       Float
  source      String
  validFrom   DateTime
  validUntil  DateTime?

  @@index([family, countryCode, key, validFrom])
}

// ————— Audit (remplace le bus Intents : une table, hash-chaînée, requêtable) —————

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      String // ex: pillar.amend, deliverable.compose, payment.approve
  entity      String?
  entityId    String?
  payload     Json?
  prevHash    String?
  selfHash    String
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([action, createdAt])
}
