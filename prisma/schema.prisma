  companyName        String
  sector             String?
  country            String?
  businessModel      String?
  economicModel      String?
  positioning        String?
  method             IntakeMethod      @default(LONG)
  responses          Json
  /// Direct financial answers from biz intake (revenue range, marketing budget, team size)
  financialResponses Json?
  rawText            String? // SHORT method: pasted text
  documentUrl        String? // INGEST: uploaded file URL
  /// Vague 10 — empreinte web publique (produit d'appel). Le site déclaré
  /// vit dans `websiteUrl` (champ existant, partagé avec INGEST_PLUS).
  socialLinksRaw     String? // liens sociaux déclarés (un par ligne)
  webFootprint       Json? // WebFootprint collecté (site/sociaux/articles/canaux)
  websiteUrl         String? // INGEST_PLUS: URL to scan
  advertis_vector    Json?
  classification     String?
  diagnostic         Json?
  shareToken         String            @unique @default(cuid())
  status             QuickIntakeStatus @default(IN_PROGRESS)
  convertedToId      String?
  // ADR-0029 — FK with onDelete: SetNull. The Strategy archive BFS purge
  // (cf. ADR-0028) reads information_schema for FKs and cascades DELETE on
  // every child row by default. With SET NULL, the DB nullifies this pointer
  // automatically on Strategy purge and the BFS skips the relation
  // (delete_rule='SET NULL' filtered in loadFks).
  convertedTo        Strategy?         @relation("QuickIntakeConvertedTo", fields: [convertedToId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  source             String?
  brandNature        String?
  completedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shareToken])
  @@index([contactEmail])
  @@index([status])
}

