// ═══════════════════════════════════════════════════════════════════
// NOTORIA — Recommendation Engine
// ═══════════════════════════════════════════════════════════════════

model Recommendation {
  id         String @id @default(cuid())
  strategyId String

  // ── Target ──
  targetPillarKey String // a|d|v|e|r|t|i|s
  targetField     String // field name in pillar Zod schema

  // ── Operation ──
  operation       String @default("SET") // SET|ADD|MODIFY|REMOVE|EXTEND
  currentSnapshot Json? // snapshot of field at generation time
  proposedValue   Json? // proposed replacement/addition
  targetMatch     Json? // {key,value} for MODIFY/REMOVE on arrays

  // ── Provenance (GOVERNANCE-NETERU) ──
  agent           String // MESTOR|ARTEMIS|GLORY_TOOL|VAULT|HUMAN
  source          String // R|T|R+T|VAULT|INTAKE|CROSS_PILLAR|SESHAT
  modelVersion    String?
  inputSnapshotId String? // ref to stored input state
  confidence      Float // 0.0 - 1.0

  // ── Editorial (Mestor writes for all sources) ──
  explain       String // 1-3 line summary
  advantages    Json? // string[] — why to apply
  disadvantages Json? // string[] — risks if applied
  urgency       String @default("SOON") // NOW|SOON|LATER

  // ── Qualification ──
  impact            String // LOW|MEDIUM|HIGH
  destructive       Boolean @default(false)
  applyPolicy       String  @default("suggest") // auto|suggest|requires_review
  validationWarning String? // Zod mismatch warning
  sectionGroup      String? // visual grouping (e.g. "catalogueParCanal.DIGITAL")

  // ── Déterminisme radical (ADR-0090 — ruler par champ + remplacement pondéré) ──
  rulerScore          Float? // verdict ruler déterministe /100 de proposedValue
  rulerVerdict        Json? // FieldRulerVerdict sérialisé (dimensions, violations, warnings)
  scoreImpactEstimate Float? // delta composite /200 simulé (preview-impact, jamais LLM)
  weightedScore       Float? // 0.45×ruler + 0.35×impact normalisé + 0.20×confidence
  predecessorId       String? // reco APPLIED que celle-ci prétend remplacer (lineage)

  // ── Lifecycle ──
  status       String    @default("PENDING") // PENDING|ACCEPTED|REJECTED|APPLIED|REVERTED|EXPIRED
  reviewedBy   String? // userId
  reviewedAt   DateTime?
  appliedAt    DateTime?
  revertedAt   DateTime?
  revertReason String?

  // ── Grouping ──
  batchId     String?
  missionType String // ADVE_INTAKE|ADVE_UPDATE|I_GENERATION|S_SYNTHESIS|SESHAT_OBSERVATION
  publishedAt DateTime? // when published to Jehuty

  // ── Relations ──
  strategy Strategy             @relation(fields: [strategyId], references: [id])
  batch    RecommendationBatch? @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId, targetPillarKey, status])
  @@index([strategyId, status])
  @@index([batchId])
  @@index([strategyId, publishedAt])
  @@index([strategyId, missionType, status])
}

model RecommendationBatch {
  id         String @id @default(cuid())
  strategyId String

  missionType   String // ADVE_INTAKE|ADVE_UPDATE|I_GENERATION|S_SYNTHESIS|SESHAT_OBSERVATION
  sourcePillars Json // ["R","T"] — pillars read
  targetPillars Json // ["A","D","V","E"] — pillars targeted

  totalRecos    Int
  pendingCount  Int
  acceptedCount Int @default(0)
  rejectedCount Int @default(0)
  appliedCount  Int @default(0)

  agent         String // MESTOR|ARTEMIS
  modelVersion  String?
  pipelineStage Int? // position in pipeline (1=ADVE, 2=I, 3=S)

  // ── Relations ──
  strategy        Strategy         @relation(fields: [strategyId], references: [id])
  recommendations Recommendation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId, missionType])
}

