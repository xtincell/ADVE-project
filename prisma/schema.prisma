model CampaignAction {
  id                   String         @id @default(cuid())
  campaignId           String
  name                 String
  category             ActionCategory
  actionType           String
  driverId             String?
  budget               Float?
  currency             String         @default("XAF")
  startDate            DateTime?
  endDate              DateTime?
  status               String         @default("PLANNED")
  specs                Json?
  kpis                 Json?
  aarrStage            String? // ACQUISITION, ACTIVATION, RETENTION, REVENUE, REFERRAL
  coutUnitaire         Float?
  uniteCosting         String? // CPM, CPC, CPL, CPA, FLAT
  rendementDecroissant Float?
  sovTarget            Float?

  // Phase 19 — Campaign tracker L2 Instrumental (ADR-0052 Cluster B — Cohérence narrative).
  // String? avec validation Zod runtime côté service (pas d'enum Prisma — pattern aligné `status`/`aarrStage`).
  manipulationModeApplied String? // "peddler" | "dealer" | "facilitator" | "entertainer"
  bigIdeaCoherenceScore   Float? // 0..1 — score LLM eval vs BigIdea + Manifesto snapshots Campaign

  // Phase 19 Vague 2 — Campaign tracker (ADR-0052 Cluster C — Superfan economy).
  // String? canonique : APPRENTI | PRATIQUANT | INITIE | FIDELE | EVANGELISTE (cf. ADR-0047 DevotionLadderTier)
  devotionRungTargeted        String? // Rung visé par cette action
  devotionTransitionsObserved Json? // [{from: tier, to: tier, count: int}] mesuré post-action via cohort match CRM

  // Phase 19 Vague 3 — Campaign tracker (ADR-0052 Cluster H — Negative space audit).
  // PostgreSQL native String[] — pillars ADVERTIS servis par cette action.
  // Audit "obligations brand non-couvertes" croise avec Manifesto.beliefs[] obligations.
  pillarServed String[] // ["A", "D", "V", "E", "R", "T", "I", "S"] subset

  // Phase 23 (ADR-0078) — Manual-first Overton delta mode (FR26 peer to FR13).
  // When non-null, culture.overtonShift consumes this operator-tagged delta
  // instead of the sector-intelligence embeddings-based result. The downstream
  // verdict is identical in shape — discriminated by IntentEmission.payload.source
  // ("MANUAL_OPERATOR" | "ALGORITHMIC"). Auditable, no fabricated downstream.
  overtonDeltaManual Float?
  // Phase 23 (ADR-0080) — Manual entry flag : true when any manual-first peer
  // path was used on this action (manual coefficient at Campaign level,
  // manual Overton delta here, manual Glory tool form, etc.). Lets the
  // operator filter "what was hand-driven" in audit views without traversing
  // IntentEmission history. Strictly informational ; does not affect logic.
  manualEntryFlag    Boolean? @default(false)

  campaign   Campaign            @relation(fields: [campaignId], references: [id])
  executions CampaignExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([category])
  @@index([manipulationModeApplied])
}

