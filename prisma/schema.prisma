  lastUsedAt  DateTime?
  expiresAt   DateTime?

  // ── Facturation API (Vague 5 — MCP billable) ──
  ratePerCallUsd       Float   @default(0.002) // tarif déterministe par call
  includedMonthlyCalls Int     @default(100) // franchise mensuelle offerte
  ownerEmail           String? // contact de facturation du détenteur

  calls      McpApiCall[]
  statements McpUsageStatement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Un call API MCP à la frontière HTTP (billable si apiKeyId, tracé sinon).
/// Source de vérité unique du metering — les statements en sont des gels.
model McpApiCall {
  id         String  @id @default(cuid())
  apiKeyId   String?
  userId     String? // calls session ADMIN (non facturés, tracés Q1)
  server     String
  tool       String
  status     String // OK|ERROR|DENIED
  durationMs Int?
  costUsd    Float   @default(0)

  apiKey McpApiKey? @relation(fields: [apiKeyId], references: [id])

  createdAt DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([server, createdAt])
}

/// Relevé mensuel gelé à l'émission : billable = max(0, calls − franchise) × tarif.
model McpUsageStatement {
  id            String    @id @default(cuid())
  apiKeyId      String
  period        String // "2026-06"
  callCount     Int
  billableCalls Int
  costUsd       Float
  currency      String    @default("USD")
  status        String    @default("ISSUED") // ISSUED|SETTLED|WAIVED
  issuedAt      DateTime  @default(now())
  settledAt     DateTime?
  paymentRef    String? // référence IntakePayment/virement

  apiKey McpApiKey @relation(fields: [apiKeyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([apiKeyId, period])
  @@index([status, period])
}

