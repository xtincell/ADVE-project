// La Fusée v7 — schéma tranche 1 (fondations).
// Doctrine : le schéma grandit PAR TRANCHES avec les WP de port (docs/REBUILD-PLAN.md §5),
// migrations additives uniquement. Postgres sur Coolify ; URL via driver adapter
// (@prisma/adapter-pg) instancié côté serveur — jamais d'url dans ce fichier.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ————— Identité & tenancy (1 app, 3 espaces par rôle — plus de portails séparés) —————

enum WorkspaceKind {
  AGENCY // UPgraders et agences partenaires
  BRAND // espace d'une marque cliente
}

enum MemberRole {
  OWNER
  OPERATOR // opérateur agence
  MEMBER // collaborateur
  CLIENT // fondateur / payeur
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  memberships   Membership[]
  talentProfile TalentProfile? // profil Guilde (WP-011) — au plus un par compte
}

model Workspace {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  kind          WorkspaceKind
  createdAt     DateTime       @default(now())
  memberships   Membership[]
  brands        Brand[]
  subscriptions Subscription[]
  payments      Payment[]
}

model Membership {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String
  role        MemberRole
  user        User       @relation(fields: [userId], references: [id])
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

// ————— Marque & méthode (le cœur : cascade ADVE → RTIS, paliers) —————

enum BrandLevel {
  LATENT
  FRAGILE
  ORDINAIRE
  FORTE
  CULTE
  ICONE
}

enum PillarKey {
  A
  D
  V
  E
  R
  T
  I
  S
}

model Brand {
  id           String        @id @default(cuid())
  workspaceId  String
  slug         String
  name         String
  sector       String?
  countryCode  String?
  level        BrandLevel    @default(LATENT)
  createdAt    DateTime      @default(now())
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  country      Country?      @relation(fields: [countryCode], references: [code])
  pillars      Pillar[]
  scores       BrandScore[]
  deliverables Deliverable[]
  campaigns    Campaign[]

  @@unique([workspaceId, slug])
}

model Pillar {
  id        String           @id @default(cuid())
  brandId   String
  key       PillarKey
  content   Json // champs du pilier (validés Zod côté serveur, source : variable bible)
  certainty Json? // fieldCertainty : INFERRED (draft IA) vs DECLARED (validé opérateur)
  version   Int              @default(1)
  updatedAt DateTime         @updatedAt
  brand     Brand            @relation(fields: [brandId], references: [id])
  revisions PillarRevision[]

  @@unique([brandId, key])
}

// Append-only : toute écriture de pilier laisse une révision (l'audit de la méthode).
model PillarRevision {
  id        String   @id @default(cuid())
  pillarId  String
  version   Int
  content   Json
  reason    String // intake | operator_amend | rtis_refresh | import
  actorId   String?
  createdAt DateTime @default(now())
  prevHash  String?
  selfHash  String?
  pillar    Pillar   @relation(fields: [pillarId], references: [id])

  @@index([pillarId, version])
}

model BrandScore {
  id         String     @id @default(cuid())
  brandId    String
  total      Float // /200, agrégat des dimensions (moteur déterministe porté du legacy)
  dimensions Json // breakdown par dimension — traçabilité complète
  level      BrandLevel
  computedAt DateTime   @default(now())
  brand      Brand      @relation(fields: [brandId], references: [id])

  @@index([brandId, computedAt])
}

// ————— Livrables (l'Oracle = un kind parmi N ; composition déterministe d'abord) —————

enum DeliverableStatus {
  DRAFT
  GENERATING
  READY
  STALE
  ARCHIVED
}

model Deliverable {
  id         String            @id @default(cuid())
  brandId    String
  kind       String // oracle | brief | manifesto | kv | ... (registre en code)
  title      String
  status     DeliverableStatus @default(DRAFT)
  content    Json?
  composedAt DateTime?
  createdAt  DateTime          @default(now())
  brand      Brand             @relation(fields: [brandId], references: [id])

  @@index([brandId, kind])
}

// ————— Funnel public (point d'entrée n°1 de la valeur) —————

enum LeadStatus {
  NEW
  QUALIFIED
  CONVERTED
  ARCHIVED
}

model IntakeLead {
  id        String     @id @default(cuid())
  email     String
  brandName String
  payload   Json // réponses du funnel — nourrit le seed ADVE à la conversion
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())

  @@index([status, createdAt])
}

// ————— Facturation (mobile money d'abord ; validation manuelle assumée en V1) —————

model Subscription {
  id          String    @id @default(cuid())
  workspaceId String
  plan        String
  status      String // pending_manual | active | expired | cancelled
  provider    String // wave | orange | mtn | moov | manual_whatsapp | stripe
  startedAt   DateTime  @default(now())
  expiresAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, status])
}

model Payment {
  id          String    @id @default(cuid())
  workspaceId String
  amount      Int // en unité mineure de currency
  currency    String // XOF | XAF | EUR ...
  method      String
  status      String
  reference   String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
}

// ————— Référentiel marché (tables seedées — jamais de barème en dur dans le code) —————

model Country {
  code      String          @id // ISO-3166 alpha-2
  name      String
  currency  String
  zone      String? // UEMOA | CEMAC | ...
  brands    Brand[]
  campaigns Campaign[]
  talents   TalentProfile[]
}

model ZoneIndex {
  id          String    @id @default(cuid())
  family      String // cost-of-living | forex | tjm | taxes | ...
  countryCode String
  key         String
  value       Float
  source      String
  validFrom   DateTime
  validUntil  DateTime?

  @@index([family, countryCode, key, validFrom])
}

// ————— Campagnes & production (tranche 2, WP-008) —————
// Pipeline Campagne → Actions → Briefs → Missions — l'essence d'ADR-0119/0120
// legacy, simplifiée : la campagne est le CADRE (les actions lui appartiennent,
// jamais d'action orpheline — ADR-0119) ; chaque étape aval franchit une GATE
// explicite (lancer la production, transformer en brief, valider le brief,
// éclater en missions, assigner/livrer/valider — ADR-0120). Les coûts d'action
// viennent du référentiel marché (ZoneIndex "action-cost" + "cost-of-living"),
// jamais du code — une action hors référentiel est honnêtement « à estimer ».

enum CampaignStatus {
  DRAFT // cadre en cours (nom, objectif, marché, actions)
  ACTIVE // production lancée — gate explicite, requiert au moins une action
  ARCHIVED
}

enum CampaignActionStatus {
  PLANNED // frame posé, coût estimé (ou à estimer)
  BRIEFED // transformée en brief de production (gate)
  CANCELLED
}

enum BriefStatus {
  DRAFT
  VALIDATED // gate explicite — condition d'éclatement en missions
}

enum MissionStatus {
  OPEN
  ASSIGNED
  DELIVERED
  VALIDATED
}

model Campaign {
  id          String           @id @default(cuid())
  brandId     String
  name        String
  objective   String // objectif déclaré par l'opérateur (registre client)
  countryCode String // marché de la campagne — résout les coûts d'action par ZoneIndex
  status      CampaignStatus   @default(DRAFT)
  launchedAt  DateTime?
  createdAt   DateTime         @default(now())
  brand       Brand            @relation(fields: [brandId], references: [id])
  country     Country          @relation(fields: [countryCode], references: [code])
  actions     CampaignAction[]

  @@index([brandId, status])
}

// Frame découplé (ADR-0120) : l'action est le CADRE de production ; le brief
// est une entité séparée, créée seulement par la gate « transformer en brief ».
model CampaignAction {
  id            String               @id @default(cuid())
  campaignId    String
  name          String
  kind          String // clé du référentiel de coûts (ZoneIndex "action-cost") ou "custom"
  status        CampaignActionStatus @default(PLANNED)
  estimatedCost Int? // résolu du référentiel à la création — null = « à estimer » (honnête)
  costCurrency  String?
  costSource    String? // traçabilité : lignes ZoneIndex consommées + méthode de mise à l'échelle
  createdAt     DateTime             @default(now())
  campaign      Campaign             @relation(fields: [campaignId], references: [id])
  briefs        Brief[]

  @@index([campaignId, status])
}

model Brief {
  id          String         @id @default(cuid())
  actionId    String
  title       String
  content     Json // brief structuré (objectif, livrable, specs, ton, échéance, contexte)
  status      BriefStatus    @default(DRAFT)
  version     Int            @default(1)
  validatedAt DateTime?
  createdAt   DateTime       @default(now())
  action      CampaignAction @relation(fields: [actionId], references: [id])
  missions    Mission[]

  @@index([actionId, status])
}

model Mission {
  id               String               @id @default(cuid())
  briefId          String
  title            String
  status           MissionStatus        @default(OPEN)
  assignee         String? // talent assigné — nom/contact déclaré (fallback hors guilde)
  // ── Guilde (tranche 3, WP-011 — champs ADDITIFS) ──
  openToGuild      Boolean              @default(false) // publiée sur le mur des missions (gate opérateur)
  assigneeTalentId String? // profil talent accepté via la Guilde (assignee = son nom, dénormalisé)
  assignedAt       DateTime?
  deliveredAt      DateTime?
  validatedAt      DateTime?
  createdAt        DateTime             @default(now())
  brief            Brief                @relation(fields: [briefId], references: [id])
  assigneeTalent   TalentProfile?       @relation(fields: [assigneeTalentId], references: [id])
  applications     MissionApplication[]

  @@index([briefId, status])
  @@index([status, createdAt])
  @@index([openToGuild, status])
}

// ————— Guilde (tranche 3, WP-011) —————
// L'essence d'ADR-0098 legacy, simplifiée : le talent tient UN profil (voie
// canonique de création — plus d'auto/seed), les missions ouvertes à la Guilde
// par l'opérateur forment le mur (cross-workspace, projection SANS donnée de
// marque), la candidature est unique par (mission, talent) et la décision
// suit APPLIED → SHORTLISTED → ACCEPTED/DECLINED. Accepter = Mission ASSIGNED
// + assigneeTalentId + candidatures sœurs DECLINED (transaction unique).

enum TalentAvailability {
  AVAILABLE // disponible pour de nouvelles missions
  BUSY // en mission — visible mais à charge
  UNAVAILABLE // indisponible (pause déclarée)
}

enum TalentVisibility {
  VISIBLE // apparaît côté marque/admin avec ses candidatures
  HIDDEN // profil retiré de la circulation (les candidatures passées restent)
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  ACCEPTED
  DECLINED
}

model TalentProfile {
  id           String               @id @default(cuid())
  userId       String               @unique // un compte = un profil talent
  headline     String // « Photographe produit — Douala » : la ligne du mur
  skills       String[]             @default([])
  city         String
  countryCode  String // référentiel Country — jamais de pays inventé
  whatsapp     String? // contact mobile money/WhatsApp — montré côté marque à l'acceptation
  portfolioUrl String?
  availability TalentAvailability   @default(AVAILABLE)
  visibility   TalentVisibility     @default(VISIBLE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id])
  country      Country              @relation(fields: [countryCode], references: [code])
  applications MissionApplication[]
  missions     Mission[] // missions gagnées via la Guilde (assigneeTalentId)

  @@index([visibility, availability])
}

model MissionApplication {
  id        String            @id @default(cuid())
  missionId String
  talentId  String // TalentProfile.id
  pitch     String
  status    ApplicationStatus @default(APPLIED)
  decidedAt DateTime? // posée au flip ACCEPTED/DECLINED
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  mission   Mission           @relation(fields: [missionId], references: [id])
  talent    TalentProfile     @relation(fields: [talentId], references: [id])

  @@unique([missionId, talentId]) // une candidature par talent et par mission
  @@index([missionId, status])
  @@index([talentId, status])
}

// ————— Audit (remplace le bus Intents : une table, hash-chaînée, requêtable) —————

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      String // ex: pillar.amend, deliverable.compose, payment.approve
  entity      String?
  entityId    String?
  payload     Json?
  prevHash    String?
  selfHash    String
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([action, createdAt])
}
