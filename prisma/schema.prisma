// ============================================================================
// LaFusee Industry OS - Prisma Schema
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 : connection URL must be passed via the driver adapter
  // (`@prisma/adapter-pg`) instantiated in src/lib/db.ts. The schema
  // datasource block is metadata only — no `url` field allowed.
}

