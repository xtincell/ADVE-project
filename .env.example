# ============================================================================
# La Fusée — Environment template
# ============================================================================
# Copy to `.env.local` (git-ignored) and fill the REQUIRED block. Never commit
# real secrets. Most integrations are "ship-without-keys" (ADR-0021 Credentials
# Vault + ADR-0079): the app boots + runs the full ADVE/RTIS flow with only the
# REQUIRED block; unset connectors return DEFERRED_AWAITING_CREDENTIALS instead
# of crashing.
# ============================================================================

# ─── REQUIRED (the app will not boot without DATABASE_URL) ──────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/lafusee?schema=public"
#
# Projet Supabase lié (cf. supabase/config.toml) : ref `myhzthcfmbcelsfbrbcf`,
# région `eu-central-1`, Postgres 17. Mot de passe DB + service-role key ne
# vivent QU'EN env var (ADR-0075) — jamais committés.
#
# ⚠️ SERVERLESS (Vercel) + Supabase : utilise le **transaction-mode pooler**
# (port 6543), PAS le session-mode (5432). En session mode le pool est borné à
# `pool_size` (15 en free tier) et sature dès la 2ᵉ instance serverless →
# erreur « EMAXCONNSESSION: max clients reached in session mode ». Exemple lié :
#   DATABASE_URL="postgresql://postgres.myhzthcfmbcelsfbrbcf:<pwd>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   # Migrations / seeds (connexion directe session-mode, port 5432) :
#   DIRECT_URL="postgresql://postgres:<pwd>@db.myhzthcfmbcelsfbrbcf.supabase.co:5432/postgres"
# Garde-fous applicatifs (src/lib/db.ts), surchargeables si besoin :
DB_POOL_MAX="5"            # connexions max par instance (défaut 5 — sûr sous pool_size 15)
DB_POOL_IDLE_MS="10000"   # relâche une connexion idle après 10 s
DB_POOL_CONN_MS="10000"   # timeout d'acquisition d'une connexion

# NextAuth v5 — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Primary LLM provider (LLM Gateway). App boots without it, but generative
# flows (Artemis briefs, Oracle, calibration) will error.
ANTHROPIC_API_KEY="sk-ant-..."

# ─── RECOMMENDED — LLM fallbacks + embeddings (gateway: Ollama → OpenAI) ────
OPENAI_API_KEY=""
OLLAMA_BASE_URL=""          # e.g. http://localhost:11434
EMBED_MODEL_NAME=""       # e.g. nomic-embed-text

# OpenRouter — La Fusée's DEFAULT text provider. The default model is owl-alpha
# (free, served here) so the OS doesn't depend on paid LLM credits. Also serves
# free embeddings (degrades to no-op when its credit is exhausted — RAG goes
# lexical, never crashes). OpenAI-API-compatible. Key: https://openrouter.ai/keys (sk-or-...).
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="owl-alpha" # text model slug served via OpenRouter (default owl-alpha — pin the exact slug)
OPENROUTER_BASE_URL=""       # optional — defaults to https://openrouter.ai/api/v1

# Premium mode — flip ON (1/true/yes/on) ONCE Anthropic/OpenAI credits are loaded
# to promote the paid Anthropic models (Opus/Sonnet) to the front of the order.
# OFF (default) → owl-alpha first (free). LLM_PRIMARY_PROVIDER wins over both.
LLM_PREMIUM_MODE=""
# Optional hard override of the primary text provider (anthropic|openrouter|ollama).
LLM_PRIMARY_PROVIDER=""

# ─── OPTIONAL — coordination multi-pod (vague B) ────────────────────────────
# Redis (redis:// ou rediss://) : pont pub/sub NSP SSE inter-pods, invalidation
# cross-pod des caches (brand-node inheritance, market-visibility kill-switch),
# claims CAS des ticks cron. SANS elle : mode single-pod honnête (historique) —
# obligatoire seulement si l'app tourne en plusieurs répliques.
REDIS_URL=""

# ─── OPTIONAL — ops / security ──────────────────────────────────────────────
CRON_SECRET=""              # bearer guarding /api/cron/*
# Daemon cron in-process (vague C) : ON par défaut en production — tire les
# routes /api/cron/* aux cadences de scheduled-ops.yml sans cron externe
# (Coolify/pm2). "0"/"off" désactive (si tu gardes le workflow GitHub seul) ;
# "1" force en dev. Jamais de tir au boot (un redeploy ne re-déclenche rien).
OPS_DAEMON=""
ADMIN_METRICS_TOKEN=""      # guards /api/admin/metrics outside dev
KNOWLEDGE_HASH_SALT=""      # k-anonymity hashing (agency economics)
INTEGRATION_TOKEN_KEY=""    # encryption key for stored OAuth tokens
DEFAULT_OPERATOR_BUDGET_USD="" # Thot default fuel budget
# Feature flags (sane defaults if unset):
ORACLE_VIA_NETERU=""
AUTO_PROMOTION_LIVE=""
DEMO_DATA_MODE=""

# ─── Phase 9 — Ptah Forge (ADR-0009) ────────────────────────────────────
# Magnific (ex-Freepik) — image/video/audio/icon/stock/classifier (95% surface)
FREEPIK_API_KEY=""
# Optionnel : alias accepté
MAGNIFIC_API_KEY=""
# Override base URL (défaut: https://api.freepik.com)
MAGNIFIC_BASE_URL=""

# Adobe Firefly Services — OAuth 2.0 server-to-server
ADOBE_FIREFLY_CLIENT_ID=""
ADOBE_FIREFLY_CLIENT_SECRET=""

# Figma — Personal Access Token
FIGMA_PAT=""

# Canva Connect — gated par flag (onboarding partnership 2-6 sem)
CANVA_ENABLED="false"
CANVA_CLIENT_ID=""
CANVA_CLIENT_SECRET=""
# Phase 1 stub — Phase 2 via oauth-integrations table
CANVA_USER_TOKEN_DEV=""

# Webhook base URL — Magnific callback (défaut: NEXTAUTH_URL)
PTAH_WEBHOOK_BASE_URL=""

# ─── Manual payment (WhatsApp + Console validation) ────────────────────────
# Production path that bypasses the auto-providers below: "Payer" redirects to
# this WhatsApp number and records a pending request the operator validates in
# /console/socle/manual-subscriptions. Digits only (country code + number).
MANUAL_PAYMENT_WHATSAPP_NUMBER="237694171799"

# ─── OPTIONAL — payment providers (env per ADR-0075) ────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Mobile money PAYOUTS (commissions talents) — Vague 5, vrais clients.
# Sans ces clés, payCommission retourne DEFERRED_AWAITING_CREDENTIALS (jamais
# de succès simulé). Wave: payout API. MTN: produit Disbursements. Orange:
# OAuth + endpoint transfert partenaire (path configurable par pays).
WAVE_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENV=sandbox
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_MONEY_TRANSFER_PATH=

WEBHOOK_SECRET=""
PAYPAL_ENV=""               # sandbox | live
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
PAYMENT_PREFER_PAYPAL=""

# ─── OPTIONAL — mobile money (Wave / Orange Money / MTN MoMo) ───────────────
WAVE_API_URL=""
ORANGE_MONEY_API_URL=""
MTN_MOMO_API_URL=""
WEBHOOK_SECRET=""
WEBHOOK_SECRET_WAVE=""
WEBHOOK_SECRET_ORANGE_MONEY=""
WEBHOOK_SECRET_MTN=""

# ─── OPTIONAL — email (Resend or SendGrid) ──────────────────────────────────
# Email transactionnel + newsletter (Vague 10 — email-sender, cascade) :
# Resend (prioritaire) > Mailgun > SendGrid. EMAIL_FROM obligatoire.
# Sans cle : CRM/newsletter repondent DEFERRED_AWAITING_CREDENTIALS.
RESEND_API_KEY=""
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
SENDGRID_API_KEY=""
EMAIL_FROM=""

# ─── OPTIONAL — external connectors (CRM / harvester) ───────────────────────
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
MONDAY_CLIENT_ID=""
MONDAY_CLIENT_SECRET=""
SESHAT_API_URL=""           # Tarsis-monitoring / Argos harvester endpoint

# ─── OPTIONAL — empreinte publique pilier E (ADR-0121, intake) ───────────────
# Collecte des données publiques du client au moment de l'intake pour combler
# le pilier E du rapport. 100 % légal (données publiques), zéro LLM.
# Sans clés : l'intake fonctionne, mode dégradé honnête (footprint déclaré seul).
BRAVE_API_KEY=""            # Brave Search API (free tier ~2000 req/mois) — découverte des profils sociaux
APIFY_TOKEN=""              # Apify pay-as-you-go (~0,001$/profil, 5$/mois gratuit) — compteurs followers réels
APIFY_IG_ACTOR_ID=""        # défaut : apify~instagram-profile-scraper ("off" désactive)
APIFY_TIKTOK_ACTOR_ID=""    # défaut : clockworks~tiktok-profile-scraper ("off" désactive)
APIFY_FB_ACTOR_ID=""        # défaut : apify~facebook-pages-scraper ("off" désactive)
# Empreinte ENTIÈRE (vague A) — score /100 + sous-blocs du rapport discovery :
YOUTUBE_API_KEY=""          # YouTube Data API v3 (gratuite, 10 000 unités/j) — stats de chaîne
PAGESPEED_API_KEY=""        # PageSpeed Insights API (gratuite, 25 000 req/j) — performance mobile
APIFY_MAPS_ACTOR_ID=""      # opt-in avis Google Business : compass~crawler-google-places ("off" désactive)
APIFY_ADS_ACTOR_ID=""       # opt-in transparence pubs Meta (actor Ad Library, "off" désactive)
# Sans clé : RDAP domaine + MX/SPF/DMARC (node:dns) tournent toujours (gratuits).

# ─── OPTIONAL — réseaux de la marque (connexions OAuth founder, ADR-0128) ────
# Le porteur de marque connecte lui-même ses comptes depuis le tableau de bord
# (à la Sprout Social). Une app OAuth par fournisseur ; redirect URI à déclarer
# chez chacun : <BASE_URL>/api/integrations/oauth/<provider>/callback.
# Sans clés : la ligne du réseau affiche « Bientôt disponible » (aucun 500).
# INTEGRATION_TOKEN_KEY (ci-dessus) est REQUISE — les tokens sont chiffrés AES-GCM.
GOOGLE_OAUTH_CLIENT_ID=""      # Google Cloud Console — scope youtube.readonly (chaîne YouTube)
GOOGLE_OAUTH_CLIENT_SECRET=""
META_OAUTH_CLIENT_ID=""        # Meta for Developers — pages_show_list + pages_read_engagement + instagram_basic
META_OAUTH_CLIENT_SECRET=""
# Instagram Business Login (ADR-0128 amendé 2026-07-14) — provider `instagram` DÉDIÉ,
# distinct de Meta : la connexion IG ne passe PLUS par une Page Facebook.
# client_id = Instagram App ID (dashboard Meta → produit Instagram → « API setup with
# Instagram login »), ≠ Meta App ID ni ID de configuration Login-for-Business. PUBLIC ; défaut code 1274394400786813.
INSTAGRAM_OAUTH_CLIENT_ID="1274394400786813"  # Instagram App ID (PUBLIC — surchargeable ; vide = défaut code)
INSTAGRAM_OAUTH_CLIENT_SECRET=""              # Instagram App Secret — EN ENV UNIQUEMENT (sans lui : « bientôt disponible »)
LINKEDIN_OAUTH_CLIENT_ID=""    # LinkedIn Developers — openid profile email (profil seul, compteurs org non inclus)
LINKEDIN_OAUTH_CLIENT_SECRET=""
X_OAUTH_CLIENT_ID=""           # X Developer Portal (OAuth 2.0 confidential + PKCE) — tweet.read users.read offline.access
X_OAUTH_CLIENT_SECRET=""
TIKTOK_OAUTH_CLIENT_ID=""      # TikTok for Developers (client_key) — user.info.basic/profile/stats (Login Kit)
TIKTOK_OAUTH_CLIENT_SECRET=
# Boutique Shopify par marque (ADR-0132) — app Partner dashboard, redirect <BASE>/api/integrations/oauth/shopify/callback
SHOPIFY_OAUTH_CLIENT_ID=
SHOPIFY_OAUTH_CLIENT_SECRET=""
